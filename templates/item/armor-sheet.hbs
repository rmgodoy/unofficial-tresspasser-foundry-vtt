<form class="{{cssClass}} trespasser-sheet item armor" autocomplete="off">
  <header class="sheet-header item-header-layout">
    <div class="header-column image-column">
      <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
    </div>

    <div class="header-column details-column">
      <h1 class="item-title">
        <input name="name" type="text" value="{{item.name}}" placeholder="{{localize 'TRESPASSER.Item.Name'}}"/>
      </h1>
  </header>

  <section class="sheet-body scrollable">
    <div class="details-grid">
        <div class="field-row">
          <label>{{localize "TRESPASSER.Item.Price"}}</label>
          <input type="number" name="system.price" value="{{system.price}}" data-dtype="Number" />
        </div>

        <div class="field-row">
          <label>{{localize "TRESPASSER.Item.Placement"}}</label>
          <select name="system.placement">
            {{#each config.placements as |label key|}}
              <option value="{{key}}" {{#if (eq ../system.placement key)}}selected{{/if}}>{{localize (concat "TRESPASSER.Item.PlacementChoices." (capitalize key))}}</option>
            {{/each}}
          </select>
        </div>
      </div>

      <div class="header-column description-column">
        <div class="trp-editor-container">
          {{editor descriptionHTML target="system.description" button=true editable=editable engine="prosemirror" resizable=true}}
        </div>
      </div>
      <div class="field-row">
        <label>{{localize "TRESPASSER.Item.ArmorRating"}}</label>
        <input type="number" name="system.armorRating" value="{{system.armorRating}}" min="0" />
      </div>

      <div class="field-row">
        <label>{{localize "TRESPASSER.Item.Weight"}}</label>
        <select name="system.weight">
          <option value="L" {{#if (eq system.weight "L")}}selected{{/if}}>{{localize "TRESPASSER.Item.WeightChoices.Light"}}</option>
          <option value="H" {{#if (eq system.weight "H")}}selected{{/if}}>{{localize "TRESPASSER.Item.WeightChoices.Heavy"}}</option>
        </select>
      </div>

      <div class="field-row">
        <label>{{localize "TRESPASSER.Item.ArmorDie"}}</label>
        <input type="text" name="system.armorDie" value="{{system.armorDie}}" placeholder="d6" />
      </div>


      <div class="field-row">
        <label>{{localize "TRESPASSER.Item.DepletionDie"}}</label>
        <select name="system.depletionDie">
          {{selectOptions config.depletionDieOptions selected=system.depletionDie localize=true}}
        </select>
      </div>


      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.broken" {{checked system.broken}} id="armor-broken-{{item.id}}"/>
        <label for="armor-broken-{{item.id}}">{{localize "TRESPASSER.Item.UsedBroken"}}</label>
      </div>

      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.equipped" {{checked system.equipped}} id="armor-equipped-{{item.id}}"/>
        <label for="armor-equipped-{{item.id}}">{{localize "TRESPASSER.Item.Equipped"}}</label>
      </div>
    </div>


    <!-- Effects Sections -->
    <div style="grid-column: span 2; margin-top: 20px; border-top: 1px solid var(--trp-border-light); padding-top: 10px;">
        {{> "systems/trespasser/templates/item/parts/effects-list.hbs" 
            title=(localize "TRESPASSER.Item.ArmorEffects") 
            items=system.effects 
            property="effects" 
            deleteClass="remove-effect"}}
    </div>
    </div>
  </section>
</form>
