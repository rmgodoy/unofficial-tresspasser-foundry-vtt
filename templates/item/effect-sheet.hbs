<form class="{{cssClass}} trespasser-sheet item effect" autocomplete="off">
  <header class="sheet-header item-header-layout">
    <div class="header-column image-column">
      <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    </div>
    <div class="header-info">
      <div class="name-group">
        <h1 class="item-title" style="margin: 0;">
        <input type="text" name="name" value="{{item.name}}" placeholder="{{localize 'TRESPASSER.ItemTypes.effect'}}" style="font-family: 'Cinzel', serif; font-size: 24px; color: var(--trp-gold-bright); border: none; border-bottom: 1px solid #555; background: transparent; width: 100%;" />
        </h1>
      </div>
    </div>
  </header>

  <section class="sheet-body scrollable">
    <div class="details-grid">
      <div class="field-row">
        <label>{{localize "TRESPASSER.Item.Type"}}</label>
        <select name="system.type">
          {{{selectOptions config.effectTypes selected=system.type localize=true}}}
        </select>
      </div>

      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.isCombat" {{checked system.isCombat}} id="effect-combat-{{item.id}}"/>
        <label for="effect-combat-{{item.id}}">{{localize "TRESPASSER.Item.IsCombat"}}</label>
      </div>

      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.isOnlyReminder" {{checked system.isOnlyReminder}} id="effect-reminder-{{item.id}}"/>
        <label for="effect-reminder-{{item.id}}">{{localize "TRESPASSER.Item.isOnlyReminder"}}</label>
      </div>
      
      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.isPrevailable" {{checked system.isPrevailable}} id="effect-prevailable-{{item.id}}"/>
        <label for="effect-prevailable-{{item.id}}">{{localize "TRESPASSER.Item.IsPrevailable"}}</label>
      </div>

      {{#if system.isOnlyReminder}}
      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.gmOnly" {{checked system.gmOnly}} id="effect-gmonly-{{item.id}}"/>
        <label for="effect-gmonly-{{item.id}}">{{localize "TRESPASSER.Item.gmOnly"}}</label>
      </div>
      {{/if}}

      <div class="field-group">
        <label>{{localize "TRESPASSER.Item.intensity"}}</label>
        <input type="number" name="system.intensity" value="{{system.intensity}}" />
      </div>

      <div class="field-group">
        <label>{{localize "TRESPASSER.Item.intensityIncrement"}}</label>
        <input type="number" name="system.intensityIncrement" value="{{system.intensityIncrement}}" />
      </div>

      {{#unless system.isOnlyReminder}}
      <div class="field-row">
        <label>{{localize "TRESPASSER.Item.targetAttribute"}}</label>
        <select name="system.targetAttribute">
          {{{selectOptions config.targetAttributes selected=system.targetAttribute localize=true}}}
        </select>
      </div>

      <div class="field-row">
        <label>{{localize "TRESPASSER.Item.modifier"}}</label>
        <input type="text" name="system.modifier" value="{{system.modifier}}" placeholder="{{localize 'TRESPASSER.Dialog.EffectEditor.ModifierPlaceholder'}}" />
        <p class="notes" style="font-size: 11px; color: var(--trp-text-dim); margin-top: -5px;">{{localize "TRESPASSER.Dialog.EffectEditor.IntensityNote"}}</p>
      </div>
      {{/unless}}

      {{#if (eq system.type 'on-trigger')}}
      <div class="field-row">
        <label>{{localize "TRESPASSER.Item.triggerWhen"}}</label>
        <select name="system.when">
          {{{selectOptions config.triggerWhen selected=system.when localize=true}}}
        </select>
      </div>

      {{!-- Compound Duration --}}
      <div class="field-row" style="flex-direction:column;gap:4px;align-items:flex-start;">
        <label>{{localize "TRESPASSER.Item.duration"}}</label>

        {{!-- Operator selector — only meaningful when 2+ conditions are present --}}
        {{#if (gt system.durationConditions.length 1)}}
        <div class="dur-operator-wrap" style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
          <span style="font-size:11px;color:var(--trp-text-dim);">{{localize "TRESPASSER.DurationLabels.Operator"}}</span>
          <select name="system.durationOperator" style="width:70px;">
            <option value="OR" {{#if (eq system.durationOperator "OR")}}selected{{/if}}>{{localize "TRESPASSER.DurationLabels.OR"}}</option>
            <option value="AND" {{#if (eq system.durationOperator "AND")}}selected{{/if}}>{{localize "TRESPASSER.DurationLabels.AND"}}</option>
          </select>
        </div>
        {{/if}}

        {{!-- Condition rows --}}
        <div id="dur-conditions-list">
          {{#each system.durationConditions as |cond idx|}}
          <div class="duration-condition-row" data-index="{{idx}}" style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
            <select class="dur-mode" name="system.durationConditions.{{idx}}.mode" style="flex:1;">
              {{{selectOptions @root.config.durationModes selected=cond.mode localize=true}}}
            </select>
            <input type="number" class="dur-value" name="system.durationConditions.{{idx}}.value"
              value="{{cond.value}}"
              style="width:52px;text-align:center;{{#unless (or (eq cond.mode 'round') (eq cond.mode 'trigger'))}}display:none;{{/unless}}" />
            {{#if @root.editable}}
            <a class="dur-remove-condition" data-index="{{idx}}" title="{{localize 'TRESPASSER.DurationLabels.RemoveCondition'}}"
              style="color:var(--trp-red-dim,#c0392b);cursor:pointer;">
              <i class="fas fa-times"></i>
            </a>
            {{/if}}
          </div>
          {{else}}
          {{!-- No conditions yet — render a default indefinite row --}}
          <div class="duration-condition-row" data-index="0" style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
            <select class="dur-mode" name="system.durationConditions.0.mode" style="flex:1;">
              {{{selectOptions @root.config.durationModes selected="indefinite" localize=true}}}
            </select>
          </div>
          {{/each}}
        </div>

        {{#if editable}}
        <a class="dur-add-condition" style="font-size:11px;cursor:pointer;">
          <i class="fas fa-plus"></i> {{localize "TRESPASSER.DurationLabels.AddCondition"}}
        </a>
        {{/if}}
      </div>
      {{/if}}

      <div class="applied-effects-section">
        <h3 class="section-title">{{localize "TRESPASSER.Item.CounterEffects"}}</h3>
        <span class="section-note">{{localize "TRESPASSER.Item.CounterEffectsNote"}}</span>
        
        <div class="drop-zone applied-effects-list" data-type="counterStates">
          {{#if system.counterStates.length}}
            {{#each system.counterStates as |cs index|}}
              {{> "systems/trespasser/templates/item/parts/effect-chip.hbs" 
                  effect=cs 
                  index=index 
                  editable=@root.editable 
                  deleteClass="counter-state-remove"
                  editableIntensity=false
              }}
            {{/each}}
          {{else}}
            <p class="notes">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.Effects"}}</p>
          {{/if}}
        </div>
      </div>

      <div class="field-row editor-row" style="margin-top: 10px;">
        <label>{{localize "TRESPASSER.Item.Description"}}</label>
        <div class="trp-editor-container">
          {{editor system.description target="system.description" button=true editable=editable engine="prosemirror" resizable=true}}
        </div>
      </div>
    </div>
  </section>
</form>
