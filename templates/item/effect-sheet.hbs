<section class="{{cssClass}} trespasser-sheet item-sheet effect-sheet" autocomplete="off">
  <header class="sheet-header item-header-layout">
    <div class="header-column image-column">
      <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    </div>
    <div class="header-info">
      <div class="name-group">
        <h1 class="item-title" style="margin: 0;">
        <input type="text" name="name" value="{{item.name}}" placeholder="{{localize 'TRESPASSER.Sheet.Header.Name'}}" style="font-family: 'Cinzel', serif; font-size: var(--fs-24); color: var(--trp-gold-bright); border: none; border-bottom: 1px solid #555; background: transparent; width: 100%;" />
        </h1>
      </div>
    </div>
  </header>

  <section class="sheet-body scrollable" data-scrollable="true">
    <div class="details-grid">
      <div class="field-row">
        <label>{{localize "TRESPASSER.Sheet.Item.Details.ItemType"}}</label>
        <select name="system.type">
          {{{selectOptions config.effectTypes selected=system.type localize=true}}}
        </select>
      </div>

      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.isCombat" {{checked system.isCombat}} id="effect-combat-{{item.id}}"/>
        <label for="effect-combat-{{item.id}}">{{localize "TRESPASSER.Sheet.Item.States.IsCombat"}}</label>
      </div>

      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.isOnlyReminder" {{checked system.isOnlyReminder}} id="effect-reminder-{{item.id}}"/>
        <label for="effect-reminder-{{item.id}}">{{localize "TRESPASSER.Sheet.Item.States.IsReminder"}}</label>
      </div>
      
      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.isPrevailable" {{checked system.isPrevailable}} id="effect-prevailable-{{item.id}}"/>
        <label for="effect-prevailable-{{item.id}}">{{localize "TRESPASSER.Sheet.Item.States.IsPrevailable"}}</label>
      </div>

      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.isLasting" {{checked system.isLasting}} id="effect-lasting-{{item.id}}"/>
        <label for="effect-lasting-{{item.id}}">{{localize "TRESPASSER.Sheet.Item.States.IsLasting"}}</label>
      </div>

      {{#if system.isOnlyReminder}}
      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.gmOnly" {{checked system.gmOnly}} id="effect-gmonly-{{item.id}}"/>
        <label for="effect-gmonly-{{item.id}}">{{localize "TRESPASSER.Sheet.Item.States.GMOnly"}}</label>
      </div>
      {{/if}}

      <div class="field-group">
        <label>{{localize "TRESPASSER.Sheet.Common.Intensity"}}</label>
        <input type="number" name="system.intensity" value="{{system.intensity}}" />
      </div>

      <div class="field-group">
        <label>{{localize "TRESPASSER.Sheet.Item.Details.IntensityIncrement"}}</label>
        <input type="number" name="system.intensityIncrement" value="{{system.intensityIncrement}}" />
      </div>

      {{#unless system.isOnlyReminder}}
      <div class="field-row">
        <label>{{localize "TRESPASSER.Sheet.Item.Details.TargetAttribute"}}</label>
        <select name="system.targetAttribute">
          {{{selectOptions config.targetAttributes selected=system.targetAttribute localize=true}}}
        </select>
      </div>

      <div class="field-row">
        <label>{{localize "TRESPASSER.Sheet.Common.Modifier"}}</label>
        <input type="text" name="system.modifier" value="{{system.modifier}}" placeholder="{{localize 'TRESPASSER.Sheet.Item.Placeholder.Modifier'}}" />
        <p class="notes" style="font-size: var(--fs-11); color: var(--trp-text-dim); margin-top: -5px;">{{localize "TRESPASSER.Sheet.Item.Details.IntensityNote"}}</p>
      </div>
      {{/unless}}

      {{#if (eq system.type 'on-trigger')}}
      <div class="field-row">
        <label>{{localize "TRESPASSER.Sheet.Common.Trigger"}}</label>
        <select name="system.when">
          {{{selectOptions config.triggerWhen selected=system.when localize=true}}}
        </select>
      </div>

      {{!-- Compound Duration --}}
      <div class="field-row" style="flex-direction:column;gap:4px;align-items:flex-start;">
        <label>{{localize "TRESPASSER.Sheet.Common.Duration"}}</label>

        {{!-- Operator selector — only meaningful when 2+ conditions are present --}}
        {{#if (gt system.durationConditions.length 1)}}
        <div class="dur-operator-wrap" style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
          <span style="font-size:var(--fs-11);color:var(--trp-text-dim);">{{localize "TRESPASSER.Sheet.Common.Operator"}}</span>
          <select name="system.durationOperator" style="width:70px;">
            <option value="OR" {{#if (eq system.durationOperator "OR")}}selected{{/if}}>{{localize "TRESPASSER.Sheet.Common.OR"}}</option>
            <option value="AND" {{#if (eq system.durationOperator "AND")}}selected{{/if}}>{{localize "TRESPASSER.Sheet.Common.AND"}}</option>
          </select>
        </div>
        {{/if}}

        {{!-- Condition rows --}}
        <div id="dur-conditions-list">
          {{#each system.durationConditions as |cond idx|}}
          <div class="duration-condition-row" data-index="{{idx}}" style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
            <select class="dur-mode" name="system.durationConditions.{{idx}}.mode" style="flex:1;">
              {{{selectOptions @root.config.durationModes selected=cond.mode localize=true}}}
            </select>
            <input type="number" class="dur-value" name="system.durationConditions.{{idx}}.value"
              value="{{cond.value}}"
              style="width:52px;text-align:center;{{#unless (or (eq cond.mode 'round') (eq cond.mode 'trigger'))}}display:none;{{/unless}}" />
            {{#if @root.editable}}
            <a class="dur-remove-condition" data-index="{{idx}}" title="{{localize 'TRESPASSER.Sheet.Common.Delete'}}"
              style="color:var(--trp-red-dim,#c0392b);cursor:pointer;">
              <i class="fas fa-times"></i>
            </a>
            {{/if}}
          </div>
          {{else}}
          {{!-- No conditions yet — render a default indefinite row --}}
          <div class="duration-condition-row" data-index="0" style="display:flex;align-items:center;gap:6px;margin-bottom:4px;">
            <select class="dur-mode" name="system.durationConditions.0.mode" style="flex:1;">
              {{{selectOptions @root.config.durationModes selected="indefinite" localize=true}}}
            </select>
          </div>
          {{/each}}
        </div>

        {{#if editable}}
        <a class="dur-add-condition" style="font-size:var(--fs-11);cursor:pointer;">
          <i class="fas fa-plus"></i> {{localize "TRESPASSER.Sheet.Common.Add"}}
        </a>
        {{/if}}
      </div>
      {{/if}}

      <div class="applied-effects-section">
        <h3 class="section-title">{{localize "TRESPASSER.Sheet.Item.Sections.CounterEffects"}}</h3>
        <span class="section-note">{{localize "TRESPASSER.Sheet.Item.Note.CounterEffects"}}</span>
        
        <div class="drop-zone applied-effects-list" data-type="counterStates">
          {{#if system.counterStates.length}}
            {{#each system.counterStates as |cs index|}}
              {{> "systems/trespasser/templates/item/parts/effect-chip.hbs" 
                  effect=cs 
                  index=index 
                  editable=@root.editable 
                  deleteClass="counter-state-remove"
                  editableIntensity=false
              }}
            {{/each}}
          {{else}}
            <p class="notes">{{localize "TRESPASSER.Sheet.Item.Placeholder.DropEffects"}}</p>
          {{/if}}
        </div>
      </div>

      <div class="field-row">
        <label>{{localize "TRESPASSER.Sheet.Item.Details.StatusIcon"}}</label>
        <div style="display:flex; align-items:center; gap:10px; width: 100%;">
          <select name="system.statusIcon" style="flex:1;">
            <option value="">{{localize "TRESPASSER.Sheet.Item.Details.NoStatusIcon"}}</option>
            {{#each config.statusEffects as |se|}}
              <option value="{{se.img}}" {{#if (eq ../system.statusIcon se.img)}}selected{{/if}}>
                {{se.name}}
              </option>
            {{/each}}
          </select>
          {{#if system.statusIcon}}
            <img src="{{system.statusIcon}}" style="width:24px; height:24px; border:none; background:transparent;" />
          {{/if}}
        </div>
      </div>

      <div class="field-row editor-row" style="margin-top: 10px;">
        <label>{{localize "TRESPASSER.Sheet.Common.Description"}}</label>
        <div class="trp-editor-container">
          <prose-mirror name="system.description" value="{{system.description}}" toggled="false" compact="false">{{{descriptionHTML}}}</prose-mirror>
        </div>
      </div>
    </div>
  </section>
</section>
