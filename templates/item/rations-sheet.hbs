<form class="{{cssClass}} trespasser-sheet item rations" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-info">
      <div class="name-group">
        <h1 class="item-title">{{item.name}}</h1>
      </div>
    </div>
  </header>

  <section class="sheet-body scrollable">
    <div class="details-grid">
      <div class="field-row">
        <label>{{localize "TRESPASSER.Sheet.Equipments.Name"}}</label>
        <input type="text" name="name" value="{{item.name}}" placeholder="{{localize 'TRESPASSER.ItemTypes.rations'}}" />
      </div>

      <div class="field-row">
        <label>{{localize "TRESPASSER.Item.DepletionDie"}}</label>
        <select name="system.depletionDie">
          {{selectOptions config.depletionDieOptions selected=system.depletionDie localize=true}}
        </select>
      </div>
      <div class="field-row checkbox-row">
        <input type="checkbox" name="system.broken" {{checked system.broken}} id="rations-broken-{{item.id}}"/>
        <label for="rations-broken-{{item.id}}">{{localize "TRESPASSER.Item.UsedBroken"}}</label>
      </div>
    </div>

    <div class="description-section" style="margin-top: 20px; border-top: 1px solid var(--trp-gold-dim); padding-top: 10px; margin-bottom: 20px;">
        <h3 style="font-family: var(--trp-font-header); color: var(--trp-gold-bright); margin-bottom: 10px;">{{localize "TRESPASSER.Item.Description"}}</h3>
        {{editor descriptionHTML target="system.description" button=true editable=editable engine="prosemirror"}}
    </div>

    <div class="effects-section" style="margin-top: 20px; border-top: 1px solid var(--trp-gold-dim); padding-top: 10px;">
        <h3 style="font-family: var(--trp-font-header); color: var(--trp-gold-bright); margin-bottom: 10px;">{{localize "TRESPASSER.Item.LinkedEffects"}}</h3>
        <div class="applied-effects-list" data-type="effects" style="min-height: 100px; border: 2px dashed var(--trp-gold-dim); border-radius: 6px; padding: 10px;">
          {{#each system.effects as |effect index|}}
            {{> "systems/trespasser/templates/item/parts/effect-chip.hbs" effect=effect index=index editable=true editableIntensity=true deleteClass="effect-remove"}}
          {{else}}
            <div class="effect-placeholder" style="text-align: center; color: var(--trp-text-dim); padding: 20px;">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.Effects"}}</div>
          {{/each}}
        </div>
    </div>
  </section>
</form>
