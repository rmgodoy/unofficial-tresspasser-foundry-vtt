<form class="{{cssClass}} trespasser-sheet item feature" autocomplete="off">
  <header class="sheet-header" style="display: flex; gap: 10px; align-items: center; border-bottom: 2px solid var(--trp-gold-border); padding-bottom: 10px; margin-bottom: 10px;">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" width="64" height="64" style="border: 2px solid var(--trp-gold-border); border-radius: 4px;" />
    <div class="header-info" style="flex: 1;">
      <h1 class="item-title" style="margin: 0;">
        <input type="text" name="name" value="{{item.name}}" placeholder="{{localize 'TRESPASSER.ItemTypes.feature'}}" style="font-family: 'Cinzel', serif; font-size: 24px; color: var(--trp-gold-bright); border: none; border-bottom: 1px solid #555; background: transparent; width: 100%;" />
      </h1>
      <div class="field-row" style="margin-top: 5px; display: flex; align-items: center; gap: 8px;">
        <label style="font-size: 11px; color: var(--trp-text-dim); text-transform: uppercase;">{{localize "TRESPASSER.Item.actionType"}}</label>
        <select name="system.type" style="font-size: 11px; height: 18px; line-height: 1; padding: 0 4px; background: rgba(0,0,0,0.3); color: var(--trp-text-bright); border: 1px solid #444;">
          {{selectOptions config.actionTypeChoices selected=system.type localize=true}}
        </select>
      </div>
    </div>
  </header>

  <section class="sheet-body scrollable" style="overflow-y: auto; padding: 10px;">
    {{!-- Description Section --}}
    <div class="description-section" style="margin-bottom: 20px; border-bottom: 2px solid var(--trp-border); padding-bottom: 15px;">
      <h3 style="margin-bottom: 5px; color: var(--trp-gold-bright);">{{localize "TRESPASSER.Item.Description"}}</h3>
      {{editor descriptionHTML target="system.description" button=true editable=editable engine="prosemirror"}}
    </div>

    {{!-- Effects & Deeds Section --}}
    <div class="links-section">
      
      <div class="applied-effects-section">
        <h3 class="section-title">{{localize "TRESPASSER.Item.LinkedEffects"}}</h3>
        <p class="section-note">{{localize "TRESPASSER.Item.LinkedEffectsNote"}}</p>
        <div class="applied-effects-list drop-zone" data-type="effects">
          {{#each linkedEffects as |effect index|}}
            {{> "systems/trespasser/templates/item/parts/effect-chip.hbs" 
                effect=effect 
                index=index 
                editable=true 
                deleteClass="effect-remove" 
                editableIntensity=true
            }}
          {{else}}
            <p class="notes">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.Effects"}}</p>
          {{/each}}
        </div>
      </div>

      <div class="applied-effects-section">
        <h3 class="section-title">{{localize "TRESPASSER.Item.LinkedDeeds"}}</h3>
        <p class="section-note">{{localize "TRESPASSER.Item.LinkedDeedsNote"}}</p>
        <div class="applied-effects-list drop-zone" data-type="deeds">
          {{#each linkedDeeds as |deed index|}}
            <div class="effect-chip deed-chip" data-index="{{index}}" style="border-radius: 20px;">
              <img src="{{deed.img}}" style="border-radius: 50%;" />
              <span class="name">{{deed.name}}</span>
              <div class="controls">
                {{#if ../editable}}
                  <a class="deed-remove remove" title="{{localize 'TRESPASSER.Item.RemoveDeed'}}"><i class="fas fa-times"></i></a>
                {{/if}}
              </div>
            </div>
          {{else}}
            <p class="notes">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.Deeds"}}</p>
          {{/each}}
        </div>
      </div>

    </div>
  </section>
</form>
