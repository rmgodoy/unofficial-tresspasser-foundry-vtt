<form class="{{cssClass}} trespasser-sheet item feature" autocomplete="off">
  <header class="sheet-header" style="display: flex; gap: 10px; align-items: center; border-bottom: 2px solid var(--trp-gold-border); padding-bottom: 10px; margin-bottom: 10px;">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" width="64" height="64" style="border: 2px solid var(--trp-gold-border); border-radius: 4px;" />
    <div class="header-info" style="flex: 1;">
      <h1 class="item-title" style="margin: 0;">
        <input type="text" name="name" value="{{item.name}}" placeholder="{{localize 'TRESPASSER.ItemTypes.feature'}}" style="font-family: 'Cinzel', serif; font-size: 24px; color: var(--trp-gold-bright); border: none; border-bottom: 1px solid #555; background: transparent; width: 100%;" />
      </h1>
    </div>
  </header>

  <section class="sheet-body scrollable" style="overflow-y: auto; padding: 10px;">
    {{!-- Description Section --}}
    <div class="description-section" style="margin-bottom: 20px; border-bottom: 2px solid var(--trp-border); padding-bottom: 15px;">
      <h3 style="margin-bottom: 5px; color: var(--trp-gold-bright);">{{localize "TRESPASSER.Item.Description"}}</h3>
      {{editor descriptionHTML target="system.description" button=true editable=editable engine="prosemirror"}}
    </div>

    {{!-- Effects & Deeds Section --}}
    <div class="links-section">
      
      <div class="effects-section" style="margin-top: 10px;">
        <h3 style="margin-bottom: 5px; color: var(--trp-gold-bright);">{{localize "TRESPASSER.Item.LinkedEffects"}}</h3>
        <p style="font-size: 11px; font-style: italic; color: var(--trp-text-dim); margin-bottom: 5px;">{{localize "TRESPASSER.Item.LinkedEffectsNote"}}</p>
        <div class="applied-effects-list drop-zone" data-type="effects" style="min-height: 48px; padding: 4px; border: 1px dashed #555; border-radius: 4px; background: rgba(0,0,0,0.2);">
          {{#each linkedEffects as |effect index|}}
            {{> "systems/trespasser/templates/item/parts/effect-chip.hbs" effect=effect index=index deleteClass="effect-remove"}}
          {{else}}
          <span style="color: #666; font-style: italic; line-height: 30px; margin-left: 8px;">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.Effects"}}</span>
          {{/each}}
        </div>
      </div>

      <div class="effects-section" style="margin-top: 20px;">
        <h3 style="margin-bottom: 5px; color: var(--trp-gold-bright);">{{localize "TRESPASSER.Item.LinkedDeeds"}}</h3>
         <p style="font-size: 11px; font-style: italic; color: var(--trp-text-dim); margin-bottom: 5px;">{{localize "TRESPASSER.Item.LinkedDeedsNote"}}</p>
        <div class="applied-effects-list drop-zone" data-type="deeds" style="min-height: 48px; padding: 4px; border: 1px dashed #555; border-radius: 4px; background: rgba(0,0,0,0.2);">
          {{#each linkedDeeds as |deed index|}}
            <div class="effect-chip" data-index="{{index}}" style="display: inline-flex; align-items: center; background: rgba(0,0,0,0.4); border: 1px solid #444; border-radius: 12px; padding: 2px 8px 2px 2px; margin: 2px; font-size: 11px;">
              <img src="{{deed.img}}" width="20" height="20" style="border: none; border-radius: 10px; margin-right: 6px;" />
              <span style="font-weight: bold; color: var(--trp-text-bright);">{{deed.name}}</span>
              <a class="deed-remove" title="{{localize 'TRESPASSER.Item.RemoveDeed'}}" style="margin-left: 6px; color: #a00; cursor: pointer;"><i class="fas fa-times"></i></a>
            </div>
          {{else}}
          <span style="color: #666; font-style: italic; line-height: 30px; margin-left: 8px;">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.Deeds"}}</span>
          {{/each}}
        </div>
      </div>

    </div>
  </section>
</form>
