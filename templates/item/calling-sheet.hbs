<form class="{{cssClass}} trespasser-sheet item calling" autocomplete="off">

  {{!-- ═══ HEADER ═══ --}}
  <header class="sheet-header" style="display:flex; gap:10px; align-items:center; border-bottom:2px solid var(--trp-gold-border); padding-bottom:10px; margin-bottom:12px;">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" width="64" height="64"
         style="border:2px solid var(--trp-gold-border); border-radius:4px; object-fit:cover; cursor:pointer;" />
    <div class="header-info" style="flex:1;">
      <h1 class="item-title" style="margin:0;">
        <input type="text" name="name" value="{{item.name}}"
               placeholder="{{localize 'TRESPASSER.ItemTypes.calling'}}"
               style="font-family:'Cinzel',serif; font-size:22px; color:var(--trp-gold-bright); border:none; border-bottom:1px solid #555; background:transparent; width:100%;" />
      </h1>
    </div>
  </header>

  <section class="sheet-body scrollable" style="overflow-y:auto; padding:10px 12px;">

    {{!-- ═══ DESCRIPTION ═══ --}}
    <div class="description-section" style="margin-bottom:16px; border-bottom:1px solid var(--trp-border); padding-bottom:12px;">
      <h4>{{localize "TRESPASSER.Item.Description"}}</h4>
      {{editor descriptionHTML target="system.description" button=true editable=editable engine="prosemirror"}}
    </div>

    {{!-- ═══ SKILLS ═══ --}}
    <div class="skills-section" style="margin-bottom:16px; border-bottom:1px solid var(--trp-border); padding-bottom:12px;">
      <h4>{{localize "TRESPASSER.Calling.Skills"}}</h4>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:2px 12px;">
        {{#each skillRows as |row|}}
          <div class="skill-row" style="display:flex; align-items:center; justify-content:space-between; padding:3px 4px;">
            <span class="skill-label">{{row.label}}</span>
            <input type="checkbox" class="calling-skill-check" data-skill="{{row.key}}" {{#if row.selected}}checked{{/if}} />
          </div>
        {{/each}}
      </div>
    </div>

    {{!-- ═══ TALENTS ═══ --}}
    <div class="calling-list-section" style="margin-bottom:16px; border-bottom:1px solid var(--trp-border); padding-bottom:12px;">
      <h4>{{localize "TRESPASSER.Calling.Talents"}}</h4>
      <p style="font-size:11px; font-style:italic; color:var(--trp-text-dim); margin-bottom:5px;">
        {{localize "TRESPASSER.Calling.DropTalentsNote"}}
      </p>
      <div class="calling-drop-zone" data-list="talents"
           style="min-height:40px; padding:4px; border:1px dashed #555; border-radius:4px; background:rgba(0,0,0,0.2); display:flex; flex-wrap:wrap; gap:4px; align-items:flex-start;">
        {{#each callingTalents as |entry index|}}
          <div class="calling-chip" data-index="{{index}}"
               style="display:inline-flex; align-items:center; background:rgba(0,0,0,0.4); border:1px solid #444; border-radius:12px; padding:2px 8px 2px 2px; font-size:11px;">
            <img src="{{entry.img}}" width="20" height="20" style="border:none; border-radius:10px; margin-right:6px;" />
            <span style="color:var(--trp-text-bright);">{{entry.name}}</span>
            {{#if @root.editable}}
              <a class="calling-item-remove" data-list="talents"
                 style="margin-left:6px; color:#a00; cursor:pointer;" title="{{localize 'TRESPASSER.Calling.Remove'}}">
                <i class="fas fa-times"></i>
              </a>
            {{/if}}
          </div>
        {{else}}
          <span style="color:#666; font-style:italic; line-height:30px; margin-left:6px;">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.Talents"}}</span>
        {{/each}}
      </div>
    </div>

    {{!-- ═══ FEATURES ═══ --}}
    <div class="calling-list-section" style="margin-bottom:16px; border-bottom:1px solid var(--trp-border); padding-bottom:12px;">
      <h4>{{localize "TRESPASSER.Calling.Features"}}</h4>
      <p style="font-size:11px; font-style:italic; color:var(--trp-text-dim); margin-bottom:5px;">
        {{localize "TRESPASSER.Calling.DropFeaturesNote"}}
      </p>
      <div class="calling-drop-zone" data-list="features"
           style="min-height:40px; padding:4px; border:1px dashed #555; border-radius:4px; background:rgba(0,0,0,0.2); display:flex; flex-wrap:wrap; gap:4px; align-items:flex-start;">
        {{#each callingFeatures as |entry index|}}
          <div class="calling-chip" data-index="{{index}}"
               style="display:inline-flex; align-items:center; background:rgba(0,0,0,0.4); border:1px solid #444; border-radius:12px; padding:2px 8px 2px 2px; font-size:11px;">
            <img src="{{entry.img}}" width="20" height="20" style="border:none; border-radius:10px; margin-right:6px;" />
            <span style="color:var(--trp-text-bright);">{{entry.name}}</span>
            {{#if @root.editable}}
              <a class="calling-item-remove" data-list="features"
                 style="margin-left:6px; color:#a00; cursor:pointer;" title="{{localize 'TRESPASSER.Calling.Remove'}}">
                <i class="fas fa-times"></i>
              </a>
            {{/if}}
          </div>
        {{else}}
          <span style="color:#666; font-style:italic; line-height:30px; margin-left:6px;">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.MagicTraits"}}</span>
        {{/each}}
      </div>
    </div>

    {{!-- ═══ ENHANCEMENTS ═══ --}}
    <div class="calling-list-section" style="margin-bottom:8px;">
      <h4>{{localize "TRESPASSER.Calling.Enhancements"}}</h4>
      <p style="font-size:11px; font-style:italic; color:var(--trp-text-dim); margin-bottom:5px;">
        {{localize "TRESPASSER.Calling.DropFeaturesNote"}}
      </p>
      <div class="calling-drop-zone" data-list="enhancements"
           style="min-height:40px; padding:4px; border:1px dashed #555; border-radius:4px; background:rgba(0,0,0,0.2); display:flex; flex-wrap:wrap; gap:4px; align-items:flex-start;">
        {{#each callingEnhancements as |entry index|}}
          <div class="calling-chip" data-index="{{index}}"
               style="display:inline-flex; align-items:center; background:rgba(0,0,0,0.4); border:1px solid #444; border-radius:12px; padding:2px 8px 2px 2px; font-size:11px;">
            <img src="{{entry.img}}" width="20" height="20" style="border:none; border-radius:10px; margin-right:6px;" />
            <span style="color:var(--trp-text-bright);">{{entry.name}}</span>
            {{#if @root.editable}}
              <a class="calling-item-remove" data-list="enhancements"
                 style="margin-left:6px; color:#a00; cursor:pointer;" title="{{localize 'TRESPASSER.Calling.Remove'}}">
                <i class="fas fa-times"></i>
              </a>
            {{/if}}
          </div>
        {{else}}
          <span style="color:#666; font-style:italic; line-height:30px; margin-left:6px;">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.MagicTraits"}}</span>
        {{/each}}
      </div>
    </div>

  </section>
</form>
