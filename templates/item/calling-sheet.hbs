<form class="{{cssClass}} trespasser-sheet item calling" autocomplete="off">

  {{!-- ═══ HEADER ═══ --}}
  <header class="sheet-header item-header-layout">
    <img class="header-column image-column" src="{{item.img}}" data-edit="img" title="{{item.name}}" width="64" height="64"
         style="border:2px solid var(--trp-gold-border); border-radius:4px; object-fit:cover; cursor:pointer;" />
    <div class="header-info" style="flex:1;">
      <h1 class="item-title" style="margin:0;">
        <input type="text" name="name" value="{{item.name}}"
               placeholder="{{localize 'TRESPASSER.Sheet.Header.Name'}}"
               style="font-family:'Cinzel',serif; font-size:var(--fs-22); color:var(--trp-gold-bright); border:none; border-bottom:1px solid #555; background:transparent; width:100%;" />
      </h1>
    </div>
  </header>

  {{!-- ═══ TAB NAVIGATION ═══ --}}
  <nav class="sheet-tabs tabs" data-group="primary" style="display:flex; border-bottom:1px solid var(--trp-border); margin-bottom:12px;">
    <a class="item" data-tab="description" style="padding:5px 15px; cursor:pointer;">{{localize "TRESPASSER.Sheet.Tabs.Description"}}</a>
    <a class="item" data-tab="progression" style="padding:5px 15px; cursor:pointer;">{{localize "TRESPASSER.Sheet.Tabs.Progression"}}</a>
  </nav>

  <section class="sheet-body scrollable">

    {{!-- ═══ TAB: DESCRIPTION ═══ --}}
    <div class="tab" data-group="primary" data-tab="description">
      {{!-- ═══ DESCRIPTION ═══ --}}
      <div class="description-section" style="margin-bottom:16px; border-bottom:1px solid var(--trp-border); padding-bottom:12px;">
        <h4>{{localize "TRESPASSER.Sheet.Common.Description"}}</h4>
        <div class="trp-editor-container">
          {{editor descriptionHTML target="system.description" button=true editable=editable engine="prosemirror" resizable=true}}
        </div>
      </div>

      {{!-- ═══ SKILLS ═══ --}}
      <div class="skills-section" style="margin-bottom:16px; border-bottom:1px solid var(--trp-border); padding-bottom:12px;">
        <h4>{{localize "TRESPASSER.Sheet.Calling.Skills"}}</h4>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:2px 12px;">
          {{#each skillRows as |row|}}
            <div class="skill-row" style="display:flex; align-items:center; justify-content:space-between; padding:3px 4px;">
              <span class="skill-label">{{row.label}}</span>
              <input type="checkbox" class="calling-skill-check" data-skill="{{row.key}}" {{#if row.selected}}checked{{/if}} />
            </div>
          {{/each}}
        </div>
      </div>

      {{!-- ═══ TALENTS ═══ --}}
      <div class="calling-list-section" style="margin-bottom:16px; border-bottom:1px solid var(--trp-border); padding-bottom:12px;">
        <h4>{{localize "TRESPASSER.Sheet.Calling.Talents"}}</h4>
        <p style="font-size:var(--fs-11); font-style:italic; color:var(--trp-text-dim); margin-bottom:5px;">
          {{localize "TRESPASSER.Sheet.Calling.DropTalentsNote"}}
        </p>
        <div class="calling-drop-zone" data-list="talents"
             style="min-height:40px; padding:4px; border:1px dashed var(--trp-border); border-radius:4px; background:var(--trp-bg-overlay); display:flex; flex-wrap:wrap; gap:4px; align-items:flex-start;">
          {{#each callingTalents as |entry index|}}
            <div class="calling-chip" data-index="{{index}}"
                 style="display:inline-flex; align-items:center; background:var(--trp-bg-overlay); border:1px solid var(--trp-border); border-radius:12px; padding:2px 8px 2px 2px; font-size:var(--fs-11);">
              <img src="{{entry.img}}" width="20" height="20" style="border:none; border-radius:10px; margin-right:6px;" />
              <span style="color:var(--trp-text-bright);">{{entry.name}}</span>
              {{#if @root.editable}}
                <a class="calling-item-remove" data-list="talents"
                   style="margin-left:6px; color:var(--trp-red); cursor:pointer;" title="{{localize 'TRESPASSER.Sheet.Common.Delete'}}">
                  <i class="fas fa-times"></i>
                </a>
              {{/if}}
            </div>
          {{else}}
            <span style="color:var(--trp-text-dim); font-style:italic; line-height:30px; margin-left:6px;">{{localize "TRESPASSER.Sheet.Item.Placeholder.DropTalents"}}</span>
          {{/each}}
        </div>
      </div>

      {{!-- ═══ FEATURES ═══ --}}
      <div class="calling-list-section" style="margin-bottom:16px; border-bottom:1px solid var(--trp-border); padding-bottom:12px;">
        <h4>{{localize "TRESPASSER.Sheet.Calling.Features"}}</h4>
        <p style="font-size:var(--fs-11); font-style:italic; color:var(--trp-text-dim); margin-bottom:5px;">
          {{localize "TRESPASSER.Sheet.Calling.DropFeaturesNote"}}
        </p>
        <div class="calling-drop-zone" data-list="features"
             style="min-height:40px; padding:4px; border:1px dashed var(--trp-border); border-radius:4px; background:var(--trp-bg-overlay); display:flex; flex-wrap:wrap; gap:4px; align-items:flex-start;">
          {{#each callingFeatures as |entry index|}}
            <div class="calling-chip" data-index="{{index}}"
                 style="display:inline-flex; align-items:center; background:var(--trp-bg-overlay); border:1px solid var(--trp-border); border-radius:12px; padding:2px 8px 2px 2px; font-size:var(--fs-11);">
              <img src="{{entry.img}}" width="20" height="20" style="border:none; border-radius:10px; margin-right:6px;" />
              <span style="color:var(--trp-text-bright);">{{entry.name}}</span>
              {{#if @root.editable}}
                <a class="calling-item-remove" data-list="features"
                   style="margin-left:6px; color:var(--trp-red); cursor:pointer;" title="{{localize 'TRESPASSER.Sheet.Common.Delete'}}">
                  <i class="fas fa-times"></i>
                </a>
              {{/if}}
            </div>
          {{else}}
            <span style="color:var(--trp-text-dim); font-style:italic; line-height:30px; margin-left:6px;">{{localize "TRESPASSER.Sheet.Item.Placeholder.DropFeatures"}}</span>
          {{/each}}
        </div>
      </div>

      {{!-- ═══ ENHANCEMENTS ═══ --}}
      <div class="calling-list-section" style="margin-bottom:8px;">
        <h4>{{localize "TRESPASSER.Sheet.Calling.Enhancements"}}</h4>
        <p style="font-size:var(--fs-11); font-style:italic; color:var(--trp-text-dim); margin-bottom:5px;">
          {{localize "TRESPASSER.Sheet.Calling.DropFeaturesNote"}}
        </p>
        <div class="calling-drop-zone" data-list="enhancements"
             style="min-height:40px; padding:4px; border:1px dashed var(--trp-border); border-radius:4px; background:var(--trp-bg-overlay); display:flex; flex-wrap:wrap; gap:4px; align-items:flex-start;">
          {{#each callingEnhancements as |entry index|}}
            <div class="calling-chip" data-index="{{index}}"
                 style="display:inline-flex; align-items:center; background:var(--trp-bg-overlay); border:1px solid var(--trp-border); border-radius:12px; padding:2px 8px 2px 2px; font-size:var(--fs-11);">
              <img src="{{entry.img}}" width="20" height="20" style="border:none; border-radius:10px; margin-right:6px;" />
              <span style="color:var(--trp-text-bright);">{{entry.name}}</span>
              {{#if @root.editable}}
                <a class="calling-item-remove" data-list="enhancements"
                   style="margin-left:6px; color:var(--trp-red); cursor:pointer;" title="{{localize 'TRESPASSER.Sheet.Common.Delete'}}">
                  <i class="fas fa-times"></i>
                </a>
              {{/if}}
            </div>
          {{else}}
            <span style="color:var(--trp-text-dim); font-style:italic; line-height:30px; margin-left:6px;">{{localize "TRESPASSER.Sheet.Item.Placeholder.DropFeatures"}}</span>
          {{/each}}
        </div>
      </div>
    </div>

    {{!-- ═══ TAB: PROGRESSION ═══ --}}
    <div class="tab" data-group="primary" data-tab="progression">
      <div class="progression-list">
        {{#each progression as |row i|}}
          <div class="progression-level {{#if (gt i 0)}}collapsed{{/if}}" data-level="{{i}}">
            <div class="level-header">
              <span class="level-title">{{localize "TRESPASSER.Sheet.Header.Level"}} {{row.level}}</span>
              <i class="fas fa-chevron-down level-toggle"></i>
            </div>
            <div class="level-content">
              <div class="prog-field">
                <label>{{localize "TRESPASSER.Sheet.Header.XP"}}:</label>
                <input type="number" class="prog-input" data-level="{{i}}" data-field="xp" value="{{row.xp}}" />
              </div>
              <div class="prog-field">
                <label>{{localize "TRESPASSER.Sheet.Header.HP"}} Base:</label>
                <input type="number" class="prog-input" data-level="{{i}}" data-field="hp" value="{{row.hp}}" />
              </div>
              <div class="prog-field">
                <label>{{localize "TRESPASSER.Sheet.Header.Skill"}} Bonus:</label>
                <input type="number" class="prog-input" data-level="{{i}}" data-field="skillBonus" value="{{row.skillBonus}}" />
              </div>
              <div class="prog-field">
                <label>{{localize "TRESPASSER.Sheet.Header.SkillDie"}}:</label>
                <input type="text" class="prog-input" data-level="{{i}}" data-field="skillDie" value="{{row.skillDie}}" placeholder="d6" />
              </div>
              <div class="prog-field">
                <label>{{localize "TRESPASSER.Sheet.Header.AttributeBonus"}}:</label>
                <input type="number" class="prog-input" data-level="{{i}}" data-field="attributePoints" value="{{row.attributePoints}}" />
              </div>
              <div class="prog-field">
                <label>{{localize "TRESPASSER.Sheet.Combat.DeedsLight"}}:</label>
                <input type="number" class="prog-input" data-level="{{i}}" data-field="deedsLight" value="{{row.deedsLight}}" />
              </div>
              <div class="prog-field">
                <label>{{localize "TRESPASSER.Sheet.Combat.DeedsHeavy"}}:</label>
                <input type="number" class="prog-input" data-level="{{i}}" data-field="deedsHeavy" value="{{row.deedsHeavy}}" />
              </div>
              <div class="prog-field">
                <label>{{localize "TRESPASSER.Sheet.Combat.DeedsMighty"}}:</label>
                <input type="number" class="prog-input" data-level="{{i}}" data-field="deedsMighty" value="{{row.deedsMighty}}" />
              </div>
              <div class="prog-field full-width">
                <label>{{localize "TRESPASSER.Sheet.CallingGrantDescription"}}:</label>
                <input type="text" class="prog-input" data-level="{{i}}" data-field="callingAbilities" value="{{row.callingAbilities}}"
                       placeholder="{{localize 'TRESPASSER.Sheet.Item.Placeholder.GrantDescription'}}" />
              </div>
            </div>
          </div>
        {{/each}}
      </div>
    </div>

  </section>
</form>
