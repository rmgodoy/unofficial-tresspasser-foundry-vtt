<form class="{{cssClass}} trespasser-sheet item talent" autocomplete="off">
  <header class="sheet-header item-header-layout">
    <div class="header-column image-column">
      <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}"/>
    </div>

    <div class="header-column details-column">
      <h1 class="item-title">
        <input name="name" type="text" value="{{item.name}}" placeholder="{{localize 'TRESPASSER.Sheet.Header.Name'}}"/>
      </h1>
    </div>
  </header>

  <section class="sheet-body scrollable">

    {{!-- Usable toggle + cost fields --}}
    <div class="description-section" style="margin-bottom: 16px; border-bottom: 1px solid var(--trp-border); padding-bottom: 12px;">
      <div class="details-grid">

        <div class="field-row">
          <label>{{localize "TRESPASSER.Sheet.Item.States.Usable"}}</label>
          <input type="checkbox" name="system.usable" {{checked system.usable}} />
        </div>

        {{#if system.usable}}
        <div class="field-row">
          <label>{{localize "TRESPASSER.Sheet.Item.Details.RollExpression"}}</label>
          <input type="text" name="system.rollDice" value="{{system.rollDice}}" placeholder="{{localize 'TRESPASSER.Sheet.Item.Placeholder.RollExpression'}}" />
        </div>
        <p class="notes" style="font-size: var(--fs-11); color: var(--trp-text-dim); margin-top: -5px; grid-column: span 2;">{{localize "TRESPASSER.Sheet.Item.Note.SkillWeaponDie"}}</p>

        <div class="field-row">
          <label>{{localize "TRESPASSER.Sheet.Item.Details.FocusCost"}}</label>
          <input type="number" name="system.focusCost" value="{{system.focusCost}}" placeholder="0" />
        </div>

        <div class="field-row">
          <label>{{localize "TRESPASSER.Sheet.Item.Details.FocusIncrease"}}</label>
          <input type="number" name="system.focusIncrease" value="{{system.focusIncrease}}" placeholder="0" />
        </div>

        <div class="field-row">
          <label>{{localize "TRESPASSER.Sheet.Item.Details.BonusCost"}}</label>
          <input type="number" name="system.bonusCost" value="{{system.bonusCost}}" placeholder="0" />
        </div>

        <div class="field-row">
          <label>{{localize "TRESPASSER.Sheet.Item.Details.ActionType"}}</label>
          <select name="system.type">
            {{selectOptions config.actionTypeChoices selected=system.type localize=true}}
          </select>
        </div>
        {{/if}}

        <div class="field-row description-column">
          <label>{{localize "TRESPASSER.Sheet.Common.Description"}}</label>
          <div class="trp-editor-container">
            {{editor descriptionHTML target="system.description" button=true editable=editable engine="prosemirror" resizable=true}}
          </div>
        </div>
      </div>
    </div>


    {{!-- Linked Effects --}}
    <div class="links-section">
      <div class="effects-section" style="margin-top: 10px;">
        <h3 style="margin-bottom: 5px; color: var(--trp-gold-bright);">{{localize "TRESPASSER.Sheet.Item.Sections.LinkedEffects"}}</h3>
        <p style="font-size: var(--fs-11); font-style: italic; color: var(--trp-text-dim); margin-bottom: 5px;">{{localize "TRESPASSER.Sheet.Item.Note.LinkedEffects"}}</p>
        <div class="applied-effects-list drop-zone" data-type="effects" style="min-height: 48px; padding: 4px; border: 1px dashed var(--trp-border); border-radius: 4px; background: var(--trp-bg-overlay);">
          {{#each system.effects as |effect index|}}
            {{> "systems/trespasser/templates/item/parts/effect-chip.hbs" effect=effect index=index editable=true editableIntensity=true deleteClass="effect-remove"}}
          {{else}}
          <span style="color: var(--trp-text-dim); font-style: italic; line-height: 30px; margin-left: 8px;">{{localize "TRESPASSER.Sheet.Item.Placeholder.DropEffects"}}</span>
          {{/each}}
        </div>
      </div>
    </div>

  </section>
</form>
