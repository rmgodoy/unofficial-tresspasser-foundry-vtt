<form class="{{cssClass}} trespasser-sheet item talent" autocomplete="off">
  <header class="sheet-header" style="display: flex; gap: 10px; align-items: center; border-bottom: 2px solid var(--trp-gold-border); padding-bottom: 10px; margin-bottom: 10px;">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" width="64" height="64" style="border: 2px solid var(--trp-gold-border); border-radius: 4px;" />
    <div class="header-info" style="flex: 1;">
      <h1 class="item-title" style="margin: 0;">
        <input type="text" name="name" value="{{item.name}}" placeholder="{{localize 'TRESPASSER.ItemTypes.talent'}}" style="font-family: 'Cinzel', serif; font-size: 24px; color: var(--trp-gold-bright); border: none; border-bottom: 1px solid #555; background: transparent; width: 100%;" />
      </h1>
    </div>
  </header>

  <section class="sheet-body scrollable" style="overflow-y: auto; padding: 10px;">

    {{!-- Usable toggle + cost fields --}}
    <div class="description-section" style="margin-bottom: 16px; border-bottom: 1px solid var(--trp-border); padding-bottom: 12px;">
      <div class="details-grid">
        <div class="field-row">
          <label>{{localize "TRESPASSER.Item.Usable"}}</label>
          <input type="checkbox" name="system.usable" {{checked system.usable}} />
        </div>

        <div class="field-row">
          <label>{{localize "TRESPASSER.Item.actionType"}}</label>
          <select name="system.type">
            {{selectOptions config.actionTypeChoices selected=system.type localize=true}}
          </select>
        </div>

        {{#if system.usable}}
        <div class="field-row">
          <label>{{localize "TRESPASSER.Item.RollExpression"}}</label>
          <input type="text" name="system.rollDice" value="{{system.rollDice}}" placeholder="{{localize 'TRESPASSER.Item.RollExpressionPlaceholder'}}" />
        </div>
        <p class="notes" style="font-size: 11px; color: var(--trp-text-dim); margin-top: -5px; grid-column: span 2;">{{localize "TRESPASSER.Item.SkillWeaponDieNote"}}</p>

        <div class="field-row">
          <label>{{localize "TRESPASSER.Item.FocusCost"}}</label>
          <input type="number" name="system.focusCost" value="{{system.focusCost}}" placeholder="0" />
        </div>

        <div class="field-row">
          <label>{{localize "TRESPASSER.Item.FocusIncrease"}}</label>
          <input type="number" name="system.focusIncrease" value="{{system.focusIncrease}}" placeholder="0" />
        </div>

        <div class="field-row">
          <label>{{localize "TRESPASSER.Item.BonusCost"}}</label>
          <input type="number" name="system.bonusCost" value="{{system.bonusCost}}" placeholder="0" />
        </div>
        {{/if}}
      </div>
    </div>

    {{!-- Description --}}
    <div class="description-section" style="margin-bottom: 20px; border-bottom: 2px solid var(--trp-border); padding-bottom: 15px;">
      <h3 style="margin-bottom: 5px; color: var(--trp-gold-bright);">{{localize "TRESPASSER.Item.Description"}}</h3>
      {{editor descriptionHTML target="system.description" button=true editable=editable engine="prosemirror"}}
    </div>

    {{!-- Linked Effects --}}
    <div class="links-section">
      <div class="effects-section" style="margin-top: 10px;">
        <h3 style="margin-bottom: 5px; color: var(--trp-gold-bright);">{{localize "TRESPASSER.Item.LinkedEffects"}}</h3>
        <p style="font-size: 11px; font-style: italic; color: var(--trp-text-dim); margin-bottom: 5px;">{{localize "TRESPASSER.Item.LinkedEffectsNote"}}</p>
        <div class="applied-effects-list drop-zone" data-type="effects" style="min-height: 48px; padding: 4px; border: 1px dashed #555; border-radius: 4px; background: rgba(0,0,0,0.2);">
          {{#each system.effects as |effect index|}}
            {{> "systems/trespasser/templates/item/parts/effect-chip.hbs" effect=effect index=index editable=true editableIntensity=true deleteClass="effect-remove"}}
          {{else}}
          <span style="color: #666; font-style: italic; line-height: 30px; margin-left: 8px;">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.Effects"}}</span>
          {{/each}}
        </div>
      </div>
    </div>

  </section>
</form>
