<div class="effects-section">
  <h3 style="font-family: var(--trp-font-header); font-size: 13px; color: var(--trp-gold-bright); margin-bottom: 5px;">{{title}}</h3>
  <div class="applied-effects-list drop-zone" data-type="{{property}}" style="min-height: 48px; padding: 4px; border: 1px dashed #4a3f2f; border-radius: 4px; background: rgba(0,0,0,0.15);">
    {{#each items as |deed index|}}
      <div class="effect-chip" data-index="{{index}}" style="display: inline-flex; align-items: center; background: rgba(0,0,0,0.4); border: 1px solid #444; border-radius: 12px; padding: 2px 8px 2px 2px; margin: 2px; font-size: 11px;">
        <img src="{{deed.img}}" width="20" height="20" style="border: none; border-radius: 10px; margin-right: 6px;" />
        <span style="font-weight: bold; color: var(--trp-text-bright);">{{deed.name}}</span>
        <a class="{{../deleteClass}}" title="{{localize 'TRESPASSER.Item.RemoveDeed'}}" style="margin-left: 6px; color: #a00; cursor: pointer;"><i class="fas fa-times"></i></a>
      </div>
    {{else}}
    <span style="color: #666; font-style: italic; font-size: 11px; margin-left: 8px;">{{localize "TRESPASSER.Sheet.Items.DropPlaceholder.Deeds"}}</span>
    {{/each}}
  </div>
</div>
