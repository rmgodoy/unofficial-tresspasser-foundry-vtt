<section class="tab log {{tab.cssClass}}" data-group="primary" data-tab="log">
  <div class="dungeon-log">

    <div class="dungeon-log-header">
      <h2>{{localize "TRESPASSER.Sheet.Dungeon.RoundLog"}}</h2>
      {{#if editable}}
      <a class="dungeon-btn" data-action="resetDungeon" data-tooltip="{{localize 'TRESPASSER.Sheet.Dungeon.Reset.Tip'}}">
        <i class="fas fa-trash"></i> {{localize "TRESPASSER.Sheet.Dungeon.Reset.Button"}}
      </a>
      {{/if}}
    </div>

    {{#if roundLog.length}}
    <div class="dungeon-log-entries">
      {{#each roundLog}}
      <div class="dungeon-log-entry">
        <span class="log-round">{{localize "TRESPASSER.Sheet.Dungeon.RoundAbbr"}}{{round}}</span>
        <span class="log-action">{{action}}</span>
        <span class="log-detail">{{detail}}</span>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="dungeon-empty-notice">{{localize "TRESPASSER.Sheet.Dungeon.NoLogEntries"}}</div>
    {{/if}}

  </div>
</section>
