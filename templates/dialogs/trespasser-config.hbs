<div class="trespasser-config-v2">
    <nav class="sheet-tabs tabs" data-group="primary">
        {{#each tabs.primary}}
        <a class="item {{this.cssClass}}" data-action="tab" data-group="primary" data-tab="{{this.id}}">
            <i class="{{this.icon}}"></i> {{localize this.label}}
        </a>
        {{/each}}
    </nav>

    <section class="content">
        {{#if isGM}}
        <!-- Mechanics Tab -->
        <div class="tab {{#if (eq tabGroups.primary 'mechanics')}}active{{/if}}" data-group="primary" data-tab="mechanics">
            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.PlayerFacingInitiative"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="playerFacingInitiative" {{checked settings.playerFacingInitiative}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.PlayerFacingInitiativeHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.ShowInitiativeInChat"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="showInitiativeInChat" {{checked settings.showInitiativeInChat}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.ShowInitiativeInChatHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.RestrictMovementAction"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="restrictMovementAction" {{checked settings.restrictMovementAction}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.RestrictMovementActionHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.RestrictHUDActions"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="restrictHUDActions" {{checked settings.restrictHUDActions}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.RestrictHUDActionsHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.RestrictAPFocusUsage"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="restrictAPFocusUsage" {{checked settings.restrictAPFocusUsage}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.RestrictAPFocusUsageHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.DisregardRangeOnAttack"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="disregardRangeOnAttack" {{checked settings.disregardRangeOnAttack}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.DisregardRangeOnAttackHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.AllowOutOfTurnMovement"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="allowOutOfTurnMovement" {{checked settings.allowOutOfTurnMovement}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.AllowOutOfTurnMovementHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.EnableRetreatDialog"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="enableRetreatDialog" {{checked settings.enableRetreatDialog}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.EnableRetreatDialogHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.ShowPerilInChat"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="showPerilInChat" {{checked settings.showPerilInChat}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.ShowPerilInChatHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.AutoEndCombatOnRetreat"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="autoEndCombatOnRetreat" {{checked settings.autoEndCombatOnRetreat}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.AutoEndCombatOnRetreatHint"}}</p>
            </div>
        </div>

        <!-- Exploration Tab -->
        <div class="tab {{#if (eq tabGroups.primary 'exploration')}}active{{/if}}" data-group="primary" data-tab="exploration">
            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.GroupCheckFullParty"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="groupCheckFullParty" {{checked settings.groupCheckFullParty}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.GroupCheckFullPartyHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.RestrictHavenEditToLeader"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="restrictHavenEditToLeader" {{checked settings.restrictHavenEditToLeader}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.RestrictHavenEditToLeaderHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.BypassHavenBuildingLimits"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="bypassHavenBuildingLimits" {{checked settings.bypassHavenBuildingLimits}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.BypassHavenBuildingLimitsHint"}}</p>
            </div>
        </div>
        {{/if}}

        <!-- Visuals Tab -->
        <div class="tab {{#if (eq tabGroups.primary 'visuals')}}active{{/if}}" data-group="primary" data-tab="visuals">
            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.ClockSize"}}</label>
                <div class="form-fields">
                    <input type="number" name="clockSize" value="{{settings.clockSize}}" min="20" max="200">
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.ClockSizeHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.FontSizeBase"}}</label>
                <div class="form-fields">
                    <input type="number" name="fontSizeBase" value="{{settings.fontSizeBase}}" min="10" max="30">
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.FontSizeBaseHint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.ConfirmItemTransfer"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="confirmItemTransfer" {{checked settings.confirmItemTransfer}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.ConfirmItemTransferHint"}}</p>
            </div>
            
            <h3 style="font-family: var(--trp-font-header); color: var(--trp-gold); text-transform: uppercase; border-bottom: 1px solid var(--trp-border); padding-bottom: 5px; margin: 20px 0 10px 0;">
                <i class="fas fa-palette"></i> {{localize "TRESPASSER.Settings.Tabs.Colors"}}
            </h3>
            
            
            <div class="color-grid">
                {{#each colors}}
                <div class="form-group color-picker-group">
                    <label>{{localize this.label}}</label>
                    <div class="form-fields">
                        <input type="color" name="{{this.key}}" value="{{this.value}}">
                        <input type="text" name="{{this.key}}_text" value="{{this.value}}" class="color-text">
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </section>

    <footer class="sheet-footer">
        <button type="submit" name="submit">
            <i class="fas fa-save"></i> {{localize "TRESPASSER.Settings.Save"}}
        </button>
        <button type="button" data-action="reset">
            <i class="fas fa-undo"></i> {{localize "TRESPASSER.Settings.ResetDefault"}}
        </button>
    </footer>
</div>
