<div class="trespasser-config-v2">
    <nav class="sheet-tabs tabs" data-group="primary">
        {{#each tabs.primary}}
        <a class="item {{this.cssClass}}" data-action="tab" data-group="primary" data-tab="{{this.id}}">
            <i class="{{this.icon}}"></i> {{localize this.label}}
        </a>
        {{/each}}
    </nav>

    <section class="content">
        {{#if isGM}}
        <!-- Mechanics Tab -->
        <div class="tab {{#if (eq tabGroups.primary 'mechanics')}}active{{/if}}" data-group="primary" data-tab="mechanics">
            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Mechanics.PlayerFacingInitiative.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="playerFacingInitiative" {{checked settings.playerFacingInitiative}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Mechanics.PlayerFacingInitiative.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Mechanics.InitiativeChat.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="showInitiativeInChat" {{checked settings.showInitiativeInChat}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Mechanics.InitiativeChat.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Mechanics.ApplyEncumbranceRules.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="applyEncumbranceRules" {{checked settings.applyEncumbranceRules}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Mechanics.ApplyEncumbranceRules.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Mechanics.RestrictMovementAction.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="restrictMovementAction" {{checked settings.restrictMovementAction}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Mechanics.RestrictMovementAction.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Mechanics.RestrictHUDActions.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="restrictHUDActions" {{checked settings.restrictHUDActions}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Mechanics.RestrictHUDActions.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Mechanics.RestrictAPFocusUsage.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="restrictAPFocusUsage" {{checked settings.restrictAPFocusUsage}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Mechanics.RestrictAPFocusUsage.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Mechanics.DisregardRangeOnAttack.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="disregardRangeOnAttack" {{checked settings.disregardRangeOnAttack}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Mechanics.DisregardRangeOnAttack.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Mechanics.AllowOutOfTurnMovement.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="allowOutOfTurnMovement" {{checked settings.allowOutOfTurnMovement}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Mechanics.AllowOutOfTurnMovement.Hint"}}</p>
            </div>
            
            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Mechanics.HideCreatureDamageRolls.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="hideCreatureDamageRolls" {{checked settings.hideCreatureDamageRolls}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Mechanics.HideCreatureDamageRolls.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Exploration.EnableRetreatDialog.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="enableRetreatDialog" {{checked settings.enableRetreatDialog}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Exploration.EnableRetreatDialog.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Exploration.ShowPerilInChat.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="showPerilInChat" {{checked settings.showPerilInChat}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Exploration.ShowPerilInChat.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Exploration.AutoEndCombatOnRetreat.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="autoEndCombatOnRetreat" {{checked settings.autoEndCombatOnRetreat}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Exploration.AutoEndCombatOnRetreat.Hint"}}</p>
            </div>
        </div>

        <!-- Exploration Tab -->
        <div class="tab {{#if (eq tabGroups.primary 'exploration')}}active{{/if}}" data-group="primary" data-tab="exploration">
            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Exploration.GroupCheckFullParty.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="groupCheckFullParty" {{checked settings.groupCheckFullParty}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Exploration.GroupCheckFullParty.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Exploration.RestrictHavenEditToLeader.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="restrictHavenEditToLeader" {{checked settings.restrictHavenEditToLeader}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Exploration.RestrictHavenEditToLeader.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Exploration.BypassHavenBuildingLimits.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="bypassHavenBuildingLimits" {{checked settings.bypassHavenBuildingLimits}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Exploration.BypassHavenBuildingLimits.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Exploration.AutomateTravelTracker.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="automateTravelTracker" {{checked settings.automateTravelTracker}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Exploration.AutomateTravelTracker.Hint"}}</p>
            </div>
        </div>
        {{/if}}

        <!-- Visuals Tab -->
        <div class="tab {{#if (eq tabGroups.primary 'visuals')}}active{{/if}}" data-group="primary" data-tab="visuals">
            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Visuals.ClockSize.Name"}}</label>
                <div class="form-fields">
                    <input type="number" name="clockSize" value="{{settings.clockSize}}" min="20" max="200">
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Visuals.ClockSize.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Visuals.FontSizeBase.Name"}}</label>
                <div class="form-fields">
                    <input type="number" name="fontSizeBase" value="{{settings.fontSizeBase}}" min="10" max="30">
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Visuals.FontSizeBase.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Visuals.ShowStatusEffectsOnTokens.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="showStatusEffectsOnTokens" {{checked settings.showStatusEffectsOnTokens}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Visuals.ShowStatusEffectsOnTokens.Hint"}}</p>
            </div>

            <div class="form-group">
                <label>{{localize "TRESPASSER.Settings.Mechanics.ConfirmItemTransfer.Name"}}</label>
                <div class="form-fields">
                    <input type="checkbox" name="confirmItemTransfer" {{checked settings.confirmItemTransfer}}>
                </div>
                <p class="notes">{{localize "TRESPASSER.Settings.Mechanics.ConfirmItemTransfer.Hint"}}</p>
            </div>
            
            <h3 style="font-family: var(--trp-font-header); color: var(--trp-gold); text-transform: uppercase; border-bottom: 1px solid var(--trp-border); padding-bottom: 5px; margin: 20px 0 10px 0;">
                <i class="fas fa-palette"></i> {{localize "TRESPASSER.Settings.Tabs.Colors"}}
            </h3>
            
            
            <div class="color-grid">
                {{#each colors}}
                <div class="form-group color-picker-group">
                    <label>{{localize this.label}}</label>
                    <div class="form-fields">
                        <input type="color" name="{{this.key}}" value="{{this.value}}">
                        <input type="text" name="{{this.key}}_text" value="{{this.value}}" class="color-text">
                    </div>
                </div>
                {{/each}}
            </div>
        </div>
    </section>

    <footer class="sheet-footer">
        <button type="submit" name="submit">
            <i class="fas fa-save"></i> {{localize "TRESPASSER.Settings.Common.Save"}}
        </button>
        <button type="button" data-action="reset">
            <i class="fas fa-undo"></i> {{localize "TRESPASSER.Settings.Common.ResetDefault"}}
        </button>
    </footer>
</div>
