<section class="tab overview {{tab.cssClass}}" data-group="primary" data-tab="overview">
  <div class="dungeon-overview">

    {{!-- A. Header Panel --}}
    <div class="dungeon-header-panel">
      <div class="dungeon-header-line-1">
        <div class="dungeon-portrait">
          <img src="{{actor.img}}" alt="{{actor.name}}" data-edit="img" />
        </div>
        <div class="dungeon-header-fields">
          <input type="text" class="dungeon-name-input" name="name" value="{{actor.name}}" placeholder="Region Name" />
          <div class="form-group">
            <label>{{localize "TRESPASSER.Sheet.Region.Hostility"}}</label>
            <select class="dungeon-field-input" name="system.hostilityTier">
              {{#each hostilityChoices}}
                <option value="{{this.value}}" {{#if (eq ../system.hostilityTier this.value)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>
          </div>
        </div>
      </div>
      <div class="dungeon-header-line-2">
        <div class="form-group">
          <label>{{localize "TRESPASSER.Sheet.Region.DefaultTerrain"}}</label>
          <select class="dungeon-field-input" name="system.defaultTerrain">
            {{#each terrainChoices as |label key|}}
              <option value="{{key}}" {{#if (eq ../system.defaultTerrain key)}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize "TRESPASSER.Sheet.Region.Weather"}}</label>
          <select class="dungeon-field-input" name="system.weather">
            {{#each weatherChoices as |label key|}}
              <option value="{{key}}" {{#if (eq ../system.weather key)}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
      </div>
    </div>

    {{!-- B. Two-Column Main Body --}}
    <div class="dungeon-body-columns">

      {{!-- Left Column: Region Status --}}
      <div class="dungeon-panel region-status-panel">
        <div class="dungeon-section-header-row">
          <h3 class="dungeon-section-header">{{localize "TRESPASSER.Sheet.Region.SessionState"}}</h3>
        </div>
        <div class="dungeon-inner-block region-status-block">
          <div class="status-item">
            <span class="status-label">{{localize "TRESPASSER.Sheet.Region.SessionState"}}:</span>
            <span class="session-status-badge state-{{system.sessionState}}">{{capitalize system.sessionState}}</span>
          </div>
          <div class="status-item">
            <span class="status-label">{{localize "TRESPASSER.Sheet.Region.CurrentDay"}}:</span>
            <span class="status-value">{{system.currentDay}}</span>
          </div>
          <div class="status-item">
            <span class="status-label">{{localize "TRESPASSER.Terms.Travel.Period.Morning"}}:</span>
            <span class="status-value">{{currentPeriodLabel}}</span>
          </div>
          <div class="status-item">
            <span class="status-label">{{localize "TRESPASSER.Terms.DC"}}:</span>
            <span class="status-value">{{currentHostility.dc}} ({{currentHostility.label}})</span>
          </div>
        </div>
      </div>

      {{!-- Right Column: Encounter Table Panel --}}
      <div class="dungeon-panel dungeon-encounter-table">
        <div class="dungeon-section-header-row">
          {{#if editable}}
          {{#if encounterTableId}}
          <a class="dungeon-btn-small encounter-corner-left" data-action="removeEncounterTable" data-tooltip="{{localize 'TRESPASSER.Sheet.Dungeon.RemoveTable'}}"><i class="fas fa-xmark"></i></a>
          {{/if}}
          {{/if}}
          <h3 class="dungeon-section-header">{{localize "TRESPASSER.Sheet.Region.Encounters"}}</h3>
          {{#if editable}}
          <a class="dungeon-btn-small encounter-corner-right" data-action="createEncounterTable" data-tooltip="{{localize 'TRESPASSER.Sheet.Dungeon.CreateTable'}}"><i class="fas fa-plus"></i></a>
          {{/if}}
        </div>
        <div class="dungeon-inner-block">
          {{#if encounterTableId}}
            <div class="encounter-formula-bar">
              <a class="encounter-formula-left encounter-roll-btn" data-action="rollEncounterTable" data-tooltip="{{localize 'TRESPASSER.Sheet.Dungeon.RollTable'}}"><i class="fas fa-dice-d20"></i> Roll</a>
              <span class="encounter-table-name">{{encounterTableName}}</span>
            </div>
            {{#if encounterTableEntries.length}}
            <div class="encounter-entries">
              {{#each encounterTableEntries}}
              <div class="encounter-entry">
                <span class="encounter-range">{{diceRange}}</span>
                {{#if img}}<img class="encounter-icon" src="{{img}}" />{{/if}}
                <span class="encounter-text">{{text}}</span>
              </div>
              {{/each}}
            </div>
            {{/if}}
          {{else}}
            <div class="encounter-drop-zone">
              <i class="fas fa-dice-d20"></i>
              <span>{{localize "TRESPASSER.Sheet.Region.DropTableHint"}}</span>
            </div>
          {{/if}}
        </div>
      </div>

    </div>

    {{!-- C. Collapsible Map Panel --}}
    <details class="dungeon-panel dungeon-map-section">
      <summary class="dungeon-section-header-row dungeon-map-summary">
        <h3 class="dungeon-section-header">{{localize "TRESPASSER.Sheet.Region.MapImage"}}</h3>
        <i class="fas fa-chevron-down dungeon-collapse-icon"></i>
      </summary>
      <div class="dungeon-inner-block dungeon-map-content">
        <div class="form-group">
          <file-picker type="image" name="system.mapImage" value="{{system.mapImage}}"></file-picker>
        </div>
        {{#if system.mapImage}}
        <div class="dungeon-map-preview">
          <img src="{{system.mapImage}}" alt="Region Map" />
        </div>
        {{/if}}
      </div>
    </details>

    {{!-- D. Description Panel --}}
    <div class="dungeon-panel dungeon-overview-description">
      <div class="dungeon-section-header-row">
        <h3 class="dungeon-section-header">{{localize "TRESPASSER.Sheet.Region.Description"}}</h3>
      </div>
      <div class="dungeon-inner-block dungeon-description-editor">
        <prose-mirror name="system.description" value="{{system.description}}" toggled="false" compact="true">{{{enrichedDescription}}}</prose-mirror>
      </div>
    </div>

  </div>
</section>
