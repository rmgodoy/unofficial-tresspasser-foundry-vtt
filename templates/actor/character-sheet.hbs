<form class="{{cssClass}} trespasser-sheet actor character" autocomplete="off">

  <!-- ═══════════════════════════════════════════════════
       HEADER
  ════════════════════════════════════════════════════ -->
  <header class="sheet-header">
    <div class="header-portrait">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
      <button type="button" class="rest-btn" title="{{localize 'TRESPASSER.Sheet.Combat.RestTooltip'}}">
        <i class="fas fa-bed"></i>
      </button>
    </div>

    <div class="header-info">
      <!-- Row 1: Name / Level / XP -->
      <div class="header-row header-identity">
        <div class="name-group">
          <input type="text" name="name" value="{{actor.name}}" placeholder="{{localize 'TRESPASSER.Sheet.Header.NamePlaceholder'}}" />
        </div>
        <div class="level-group">
          <label>{{localize "TRESPASSER.Sheet.Header.Level"}}</label>
          <input type="number" name="system.level" value="{{system.level}}" min="0" max="9" />
        </div>
        <div class="xp-group">
          <label>{{localize "TRESPASSER.Sheet.Header.XP"}}</label>
          <input type="number" name="system.xp" value="{{system.xp}}" min="0" />
          <span class="xp-sep">/</span>
          <input type="number" name="system.xp_to_next_level" value="{{system.xp_to_next_level}}" readonly />
        </div>
      </div>

      <!-- Row 2: Resources -->
      <div class="header-row header-resources">
        <div class="resource-box">
          <label>{{localize "TRESPASSER.Sheet.Header.HP"}}</label>
          <div class="resource-values">
            <input type="number" name="system.health" value="{{system.health}}" min="0" />
            <span>/</span>
            <input type="number" name="system.max_health" value="{{system.max_health}}" readonly />
          </div>
        </div>
        <div class="resource-box" data-action="spend-rd">
          <label class="rollable">{{localize "TRESPASSER.Sheet.Header.RD"}}</label>
          <div class="resource-values">
            <input type="number" name="system.recovery_dice" value="{{system.recovery_dice}}" min="0" />
            <span>/</span>
            <input type="number" name="system.max_recovery_dice" value="{{system.max_recovery_dice}}" readonly />
          </div>
        </div>
        <div class="resource-box">
          <label>{{localize "TRESPASSER.Sheet.Header.Endurance"}}</label>
          <div class="resource-values">
            <input type="number" name="system.endurance" value="{{system.endurance}}" min="0" />
            <span>/</span>
            <input type="number" name="system.max_endurance" value="{{system.max_endurance}}" readonly />
          </div>
        </div>
        <div class="resource-box">
          <label>{{localize "TRESPASSER.Sheet.Header.Skill"}}</label>
          <input type="number" name="system.skill" value="{{system.skill}}" readonly />
        </div>
        <div class="resource-box">
          <label>{{localize "TRESPASSER.Sheet.Header.SkillDie"}}</label>
          <input type="text" name="system.skill_die" value="{{system.skill_die}}" readonly style="text-align: center;" />
        </div>
      </div>

      <!-- Row 3: Attributes with key-attribute star -->
      <!-- Row 3: Attributes with vertical layout -->
      <div class="header-row header-attributes">
        {{#each (array "mighty" "agility" "intellect" "spirit") as |attr|}}
        <div class="attribute-box">
          <span class="attribute-label attribute-roll rollable"
                data-attribute="{{attr}}"
                title="{{localize 'TRESPASSER.Sheet.Combat.ClickRollCheck' label=(localize (concat 'TRESPASSER.Sheet.Attributes.' (capitalize attr)))}}">
            {{localize (concat "TRESPASSER.Sheet.Attributes." (capitalize attr))}}
          </span>
          <input type="number" name="system.attributes.{{attr}}" value="{{lookup ../system.attributes attr}}" min="0" />
          <button type="button"
            class="key-attr-btn {{#if (eq ../keyAttribute attr)}}is-key{{/if}}"
            data-attribute="{{attr}}"
            title="{{localize 'TRESPASSER.Sheet.Header.SetKeyAttr'}}">
            {{#if (eq ../keyAttribute attr)}}★{{else}}☆{{/if}}
          </button>
        </div>
        {{/each}}
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════════════
       TAB NAVIGATION
  ════════════════════════════════════════════════════ -->
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="character">{{localize "TRESPASSER.Sheet.Tabs.Character"}}</a>
    <a class="item" data-tab="equipments">{{localize "TRESPASSER.Sheet.Tabs.Equipments"}}</a>
    <a class="item" data-tab="inventory">{{localize "TRESPASSER.Sheet.Tabs.Inventory"}}</a>
    <a class="item" data-tab="features">{{localize "TRESPASSER.Sheet.Tabs.Features"}}</a>
    <a class="item" data-tab="combat">{{localize "TRESPASSER.Sheet.Tabs.Combat"}}</a>
  </nav>

  <!-- ═══════════════════════════════════════════════════
       SHEET BODY
  ════════════════════════════════════════════════════ -->
  <section class="sheet-body">

    <!-- ─── TAB 1: CHARACTER ─── -->
    <div class="tab tab-body" data-group="primary" data-tab="character">
      <div class="character-layout">

        <!-- Column 1: Identity -->
        <div class="char-col char-identity">
          <div class="field-block">
            <label>{{localize "TRESPASSER.Sheet.Character.Calling"}}</label>
            <input type="text" name="system.calling" value="{{system.calling}}" />
          </div>
          <div class="field-block">
            <label>{{localize "TRESPASSER.Sheet.Character.Crafts"}}</label>
            <input type="text" name="system.crafts.0" value="{{craftsSlots.[0]}}" />
            <input type="text" name="system.crafts.1" value="{{craftsSlots.[1]}}" />
            <input type="text" name="system.crafts.2" value="{{craftsSlots.[2]}}" />
          </div>
          <div class="field-block">
            <label>{{localize "TRESPASSER.Sheet.Character.PastLife"}}</label>
            <input type="text" name="system.past_life" value="{{system.past_life}}" />
          </div>
          <div class="field-block">
            <label>{{localize "TRESPASSER.Sheet.Character.Lineage"}}</label>
            <input type="text" name="system.lineage" value="{{system.lineage}}" />
          </div>
          <div class="field-block">
            <label>{{localize "TRESPASSER.Sheet.Character.Alignments"}}</label>
            {{#each system.alignment as |align i|}}
            <div class="alignment-row">
              <!-- 3 left checkboxes -->
              <div class="alignment-boxes alignment-boxes-left">
                {{#each align.leftBoxes as |checked j|}}
                <input type="checkbox"
                       class="alignment-check"
                       name="system.alignment.{{i}}.leftBoxes.{{j}}"
                       {{#if checked}}checked{{/if}} />
                {{/each}}
              </div>

              <!-- Name -->
              <input type="text"
                     class="alignment-name"
                     name="system.alignment.{{i}}.name"
                     value="{{align.name}}"
                     placeholder="—" />

              <!-- 3 right checkboxes -->
              <div class="alignment-boxes alignment-boxes-right">
                {{#each align.rightBoxes as |checked j|}}
                <input type="checkbox"
                       class="alignment-check"
                       name="system.alignment.{{i}}.rightBoxes.{{j}}"
                       {{#if checked}}checked{{/if}} />
                {{/each}}
              </div>
            </div>
            {{/each}}
          </div>
        </div>

        <!-- Column 2: Skills -->
        <div class="char-col char-skills">
          <h4>{{localize "TRESPASSER.Sheet.Character.Skills"}}</h4>
          {{#each skillList}}
          <div class="skill-row">
            <span class="skill-label rollable" data-skill="{{this.key}}" title="{{localize 'TRESPASSER.Sheet.Combat.ClickRollCheck' label=this.label}}">{{this.label}}</span>
            <input type="checkbox" name="system.skills.{{this.key}}" {{trespasserChecked this.value}} />
          </div>
          {{/each}}
        </div>

        <!-- Column 3: Injuries -->
        <div class="char-col char-injuries">
          <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--trp-border); padding-bottom: 3px; margin-bottom: 6px;">
            <h4 style="margin: 0; border: none;">{{localize "TRESPASSER.Sheet.Character.Injuries"}}</h4>
            {{#if (trespasserGt 3 injuryCount)}}
            <a class="item-create button injury-create" data-type="injury" style="font-size: 11px; padding: 1px 6px;">+</a>
            {{/if}}
          </div>

          {{#each injurySlots}}
          <div class="injury-card {{#if this}}has-injury{{/if}}" data-item-id="{{#if this}}{{this.id}}{{/if}}">
            {{#if this}}

              <!-- Name area: takes remaining space; controls are absolute inside here -->
              <div class="injury-name-area">
                <span class="injury-name item-name">{{this.name}}</span>
                <div class="injury-card-controls">
                  <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
                </div>
              </div>

              <!-- SVG Clock — fixed-size, always on the right, never displaced -->
              <div class="injury-clock-widget">
                <svg class="injury-clock-mini" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
                  <circle cx="50" cy="50" r="44"
                          fill="var(--trp-bg-panel)"
                          stroke="var(--trp-border-light)"
                          stroke-width="2"/>
                  {{#each this.clockSegments as |seg i|}}
                  <path class="clock-segment-mini {{#if seg.filled}}filled{{/if}}"
                        data-item-id="{{../this.id}}"
                        data-index="{{i}}"
                        d="{{seg.path}}" />
                  {{/each}}
                  <text x="50" y="46" class="clock-label-num">{{this.system.currentClock}}</text>
                  <line x1="34" y1="50" x2="66" y2="50"
                        stroke="var(--trp-border-light)" stroke-width="1.2"/>
                  <text x="50" y="62" class="clock-label-total">{{this.system.injuryClock}}</text>
                </svg>
              </div>

            {{else}}
              <!-- Empty slot -->
              <span class="injury-empty-slot">—</span>
            {{/if}}
          </div>
          {{/each}}

        </div>


      </div>

      {{!-- Effects (Non-Combat) --}}
      <div class="effects-panel" style="margin-top: 15px; border-top: 2px solid #444; padding-top: 10px;">
        <h4 style="display: flex; justify-content: space-between; align-items: center;">
          {{localize "TRESPASSER.Sheet.Character.NonCombatEffects"}}
          <a class="item-create button" data-type="effect">+</a>
        </h4>
        <div class="effects-list">
          {{#each activeEffects.nonCombat}}
          <div class="effect-row" data-item-id="{{this.id}}" style="display: flex; align-items: center; background: rgba(0,0,0,0.2); margin-bottom: 5px; padding: 5px; border-radius: 4px; {{#if this.fromInjury}}border-left: 2px solid var(--trp-red-dim);{{/if}}">
            <div style="flex: 1;">
              <b>{{this.name}}</b>
              <a class="effect-info" title="{{localize 'TRESPASSER.Sheet.Equipments.Info'}}"><i class="fas fa-info-circle"></i></a>
              {{#if this.sourceName}} <span style="font-size: 11px; font-weight: normal; color: var(--trp-text-dim);">({{this.sourceName}})</span>{{/if}}
              {{#if this.fromInjury}}<span style="font-size: 10px; color: var(--trp-red); margin-left: 4px;" title="{{localize 'TRESPASSER.Item.Injury.FromInjury'}}">⚕</span>{{/if}}
              (I: {{this.intensity}}) - {{this.target}}: {{this.modifier}}
            </div>
            {{#unless this.fromInjury}}
            <a class="effect-remove" title="{{localize 'TRESPASSER.Item.RemoveEffect'}}"><i class="fas fa-trash"></i></a>
            {{/unless}}
          </div>
          {{else}}
          <p class="notes">{{localize "TRESPASSER.Sheet.Character.NoNonCombatEffects"}}</p>
          {{/each}}
        </div>
      </div>
    </div>


    <!-- ─── TAB 2: EQUIPMENTS ─── -->
    <div class="tab tab-body" data-group="primary" data-tab="equipments">

      <!-- Weapons -->
      <div class="equip-section">
        <table class="equip-table weapons-table">
          <thead>
            <tr>
              <th style="width: 80px;"></th>
              <th style="width: 120px;">{{localize "TRESPASSER.Sheet.Equipments.Weapon"}}</th>
              <th style="width: 40px; text-align: center;">{{localize "TRESPASSER.Sheet.Equipments.WD"}}</th>
              <th style="width: 120px; text-align: center;">{{localize "TRESPASSER.Sheet.Equipments.TypesRange"}}</th>
              <th style="min-width: 100px;">{{localize "TRESPASSER.Sheet.Equipments.Effect"}}</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="slot-label">{{localize "TRESPASSER.Sheet.Equipments.MainHand"}}</td>
              <td>
                {{#if equippedWeapon.main_hand}}
                  <span class="item-name">{{equippedWeapon.main_hand.name}}</span>
                {{else}}
                  <span style="color: #666; font-style: italic;">—</span>
                {{/if}}
              </td>
              <td style="text-align: center;">{{#if equippedWeapon.main_hand}}{{equippedWeapon.main_hand.system.weaponDie}}{{/if}}</td>
              <td style="text-align: center;">
                {{#if equippedWeapon.main_hand}}
                  {{capitalize equippedWeapon.main_hand.system.type}}
                  {{#if equippedWeapon.main_hand.system.range}}/ {{equippedWeapon.main_hand.system.range}}{{/if}}
                {{/if}}
              </td>
              <td>
                <div class="equip-effect-row" style="display: flex; align-items: center; justify-content: space-between;">
                  {{#if equippedWeapon.main_hand}}
                    <span class="item-effect">{{equippedWeapon.main_hand.effectSummary}}</span>
                    <a class="item-unequip" data-item-id="{{equippedWeapon.main_hand.id}}" title="{{localize 'TRESPASSER.Sheet.Equipments.Unequip'}}" style="cursor: pointer; font-size: 11px;"><i class="fas fa-times-circle"></i></a>
                  {{else}}
                    <span style="color: #666; font-style: italic;">{{localize "TRESPASSER.Sheet.Equipments.Empty"}}</span>
                  {{/if}}
                </div>
              </td>
            </tr>
            <tr>
              <td class="slot-label">{{localize "TRESPASSER.Sheet.Equipments.OffHand"}}</td>
              <td>
                {{#if equippedWeapon.off_hand}}
                  <span class="item-name">{{equippedWeapon.off_hand.name}}</span>
                {{else}}
                  <span style="color: #666; font-style: italic;">—</span>
                {{/if}}
              </td>
              <td style="text-align: center;">{{#if equippedWeapon.off_hand}}{{equippedWeapon.off_hand.system.weaponDie}}{{/if}}</td>
              <td style="text-align: center;">
                {{#if equippedWeapon.off_hand}}
                  {{capitalize equippedWeapon.off_hand.system.type}}
                  {{#if equippedWeapon.off_hand.system.range}}/ {{equippedWeapon.off_hand.system.range}}{{/if}}
                {{/if}}
              </td>
              <td>
                <div class="equip-effect-row" style="display: flex; align-items: center; justify-content: space-between;">
                  {{#if equippedWeapon.off_hand}}
                    <span class="item-effect">{{equippedWeapon.off_hand.effectSummary}}</span>
                    <a class="item-unequip" data-item-id="{{equippedWeapon.off_hand.id}}" title="{{localize 'TRESPASSER.Sheet.Equipments.Unequip'}}" style="cursor: pointer; font-size: 11px;"><i class="fas fa-times-circle"></i></a>
                  {{else}}
                    <span style="color: #666; font-style: italic;">{{localize "TRESPASSER.Sheet.Equipments.Empty"}}</span>
                  {{/if}}
                </div>
              </td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Armor -->
      <div class="equip-section">
        <table class="equip-table armor-table">
          <thead>
            <tr>
              <th>{{localize "TRESPASSER.Sheet.Equipments.Armor"}}</th>
              <th style="min-width: 120px;">{{localize "TRESPASSER.Sheet.Equipments.Name"}}</th>
              <th>{{localize "TRESPASSER.Sheet.Equipments.WGT"}}</th>
              <th>{{localize "TRESPASSER.Sheet.Equipments.AR"}}</th>
              <th>{{localize "TRESPASSER.Sheet.Equipments.DIE"}}</th>
              <th>{{localize "TRESPASSER.Sheet.Equipments.Effect"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each equippedArmor as |item slot|}}
            <tr>
              <td><label class="slot-label">{{localize (concat "TRESPASSER.Sheet.Equipments." (capitalize slot))}}</label></td>
              <td>
                {{#if item}}
                  <span class="item-name">{{item.name}}</span>
                {{else}}
                  <span style="color: #666; font-style: italic;">—</span>
                {{/if}}
              </td>
              <td>
                <div class="col-sm" style="text-align: center;">
                  {{#if item}}{{localize (concat "TRESPASSER.Item.WeightChoices.Short." item.system.weight)}}{{else}}—{{/if}}
                </div>
              </td>
              <td>
                <div class="col-sm" style="text-align: center;">
                  {{#if item}}{{item.system.armorRating}}{{else}}0{{/if}}
                </div>
              </td>
              <td>
                <div class="col-sm" style="text-align: center;">
                  {{#if item}}{{item.system.armorDie}}{{else}}—{{/if}}
                </div>
              </td>
              <td>
                <div class="equip-effect-row" style="display: flex; align-items: center; justify-content: space-between;">
                  {{#if item}}
                    <span class="item-effect">{{item.effectSummary}}</span>
                    <a class="item-unequip" data-item-id="{{item.id}}" title="{{localize 'TRESPASSER.Sheet.Equipments.Unequip'}}" style="cursor: pointer; font-size: 11px;"><i class="fas fa-times-circle"></i></a>
                  {{else}}
                    <span style="color: #666; font-style: italic;">{{localize "TRESPASSER.Sheet.Equipments.Empty"}}</span>
                  {{/if}}
                </div>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <!-- Accessories -->
      <div class="equip-section">
        <table class="equip-table accessory-table">
          <thead>
            <tr>
              <th>{{localize "TRESPASSER.Sheet.Equipments.Accessory"}}</th>
              <th style="width: 150px;">{{localize "TRESPASSER.Sheet.Equipments.Name"}}</th>
              <th style="width: 60px;">{{localize "TRESPASSER.Sheet.Equipments.Die"}}</th>
              <th>{{localize "TRESPASSER.Sheet.Equipments.Effect"}}</th>
            </tr>
          </thead>
          <tbody>
            {{#each equippedAccessories as |item slot|}}
            <tr>
              <td class="slot-label">{{localize (concat "TRESPASSER.Sheet.Equipments." (capitalize slot))}}</td>
              <td>
                {{#if item}}
                  <span class="item-name">{{item.name}}</span>
                {{else}}
                  <span style="color: #666; font-style: italic;">—</span>
                {{/if}}
              </td>
              <td style="text-align: center;">—</td>
              <td>
                <div class="equip-effect-row" style="display: flex; align-items: center; justify-content: space-between;">
                  {{#if item}}
                    <span class="item-effect">{{item.effectSummary}}</span>
                    <a class="item-unequip" data-item-id="{{item.id}}" title="{{localize 'TRESPASSER.Sheet.Equipments.Unequip'}}" style="cursor: pointer; font-size: 11px;"><i class="fas fa-times-circle"></i></a>
                  {{else}}
                    <span style="color: #666; font-style: italic;">{{localize "TRESPASSER.Sheet.Equipments.Empty"}}</span>
                  {{/if}}
                </div>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>

    <!-- ─── TAB 3: INVENTORY ─── -->
    <div class="tab tab-body" data-group="primary" data-tab="inventory">
      <div class="inventory-header">
        <span class="inventory-cap">{{localize "TRESPASSER.Sheet.Character.UnequippedSlots"}}: {{inventorySlotsUsed}} / {{inventoryMax}}</span>
        <a class="item-create button" data-type="weapon" title="{{localize "TRESPASSER.Sheet.Character.AddItem"}}">+ {{localize "TRESPASSER.Sheet.Character.AddItem"}}</a>
      </div>
      
      <div class="inventory-grid">
        {{#each unequippedItems}}
        <div class="inventory-card {{#if this.system.broken}}is-broken{{/if}}" data-item-id="{{this.id}}">
          {{#if this.system.broken}}<i class="fas fa-bolt broken-icon" title="{{localize "TRESPASSER.Item.BrokenUsed"}}"></i>{{/if}}
          <img src="{{this.img}}" class="item-icon" title="{{this.name}}" />
          <span class="item-name">{{this.name}}</span>
          <div class="item-controls">
            {{#if (or (eq this.type "armor") (eq this.type "weapon") (eq this.type "accessory") (and (eq this.type "item") (eq this.system.subType "light_source")))}}
            <a class="item-deplete" title="{{localize 'TRESPASSER.Sheet.Inventory.DepletionRoll' die=this.system.depletionDie}}"><i class="fas fa-dice-d6"></i></a>
            <a class="item-equip" title="{{localize 'TRESPASSER.Sheet.Equipments.Equip'}}"><i class="fas fa-hand-paper"></i></a>
            {{else if (eq this.type "rations")}}
            <a class="item-deplete" title="{{localize 'TRESPASSER.Sheet.Inventory.DepletionRoll' die=this.system.depletionDie}}"><i class="fas fa-utensils"></i></a>
            {{/if}}
            
            {{#if (eq this.system.subType "light_source")}}
            <a class="item-toggle-light" title="{{#if this.system.active}}{{localize 'TRESPASSER.Sheet.Equipments.Unlight'}}{{else}}{{localize 'TRESPASSER.Sheet.Equipments.LightSource'}}{{/if}}">
                <i class="fas fa-fire {{#if this.system.active}}active{{/if}}" style="{{#if this.system.active}}color: var(--trp-gold-bright);{{else}}color: #555;{{/if}}"></i>
            </a>
            {{/if}}

            {{#if (or (eq this.system.subType "bombs") (eq this.system.subType "oils") (eq this.system.subType "powders") (eq this.system.subType "potions") (eq this.system.subType "scrolls") (eq this.system.subType "esoteric"))}}
            <a class="item-consume" title="{{localize 'TRESPASSER.Sheet.Equipments.ConsumeUse'}}"><i class="fas fa-flask"></i></a>
            {{/if}}

            <a class="item-edit" title="{{localize 'TRESPASSER.Sheet.Equipments.Edit'}}"><i class="fas fa-edit"></i></a>
            <a class="item-delete" title="{{localize 'TRESPASSER.Sheet.Equipments.Delete'}}"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{else}}
        <div class="empty-list" style="grid-column:1/-1">{{localize "TRESPASSER.Sheet.Inventory.EmptyInventory"}}</div>
        {{/each}}
      </div>

      <div class="inventory-separator">
        <span>{{localize "TRESPASSER.Sheet.Inventory.EquippedItems"}}</span>
      </div>

      <div class="inventory-grid">
        {{#each equippedItems}}
        <div class="inventory-card {{#if this.system.broken}}is-broken{{/if}}" data-item-id="{{this.id}}">
          {{#if this.system.broken}}<i class="fas fa-bolt broken-icon" title="{{localize 'TRESPASSER.Item.BrokenUsed'}}"></i>{{/if}}
          <img src="{{this.img}}" class="item-icon" title="{{this.name}}" />
          <span class="item-name">{{this.name}}{{#if (eq this.system.subType "resource")}} <span style="font-size:11px; color:#888;">(x{{this.system.quantity}})</span>{{/if}}</span>
          <div class="item-controls">
            {{#if (or (eq this.type "armor") (eq this.type "weapon") (eq this.type "accessory") (and (eq this.type "item") (eq this.system.subType "light_source")))}}
            <a class="item-deplete" title="{{localize 'TRESPASSER.Sheet.Inventory.DepletionRoll' die=this.system.depletionDie}}"><i class="fas fa-dice-d6"></i></a>
            <a class="item-unequip" title="{{localize 'TRESPASSER.Sheet.Equipments.Unequip'}}"><i class="fas fa-hand-paper" style="color: var(--trp-gold-bright);"></i></a>
            {{else if (eq this.type "rations")}}
            <a class="item-deplete" title="{{localize 'TRESPASSER.Sheet.Inventory.DepletionRoll' die=this.system.depletionDie}}"><i class="fas fa-utensils"></i></a>
            {{/if}}

            {{#if (or (eq this.system.subType "light_source") (and (eq this.type "weapon") this.system.isLightSource))}}
            <a class="item-toggle-light" title="{{#if this.system.active}}{{localize 'TRESPASSER.Sheet.Equipments.Unlight'}}{{else}}{{localize 'TRESPASSER.Sheet.Equipments.LightSource'}}{{/if}}">
                <i class="fas fa-fire {{#if this.system.active}}active{{/if}}" style="{{#if this.system.active}}color: var(--trp-gold-bright);{{else}}color: #555;{{/if}}"></i>
            </a>
            {{/if}}

            <a class="item-edit" title="{{localize 'TRESPASSER.Sheet.Equipments.Edit'}}"><i class="fas fa-edit"></i></a>
            <a class="item-delete" title="{{localize 'TRESPASSER.Sheet.Equipments.Delete'}}"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{else}}
        <div class="empty-list" style="grid-column:1/-1">{{localize "TRESPASSER.Sheet.Inventory.EmptyEquipped"}}</div>
        {{/each}}
      </div>
    </div>

    <!-- ─── TAB 4: FEATURES ─── -->
    <div class="tab tab-body" data-group="primary" data-tab="features">
      <div class="features-layout">
        <div class="features-panel">
          <div class="panel-header">
            <h4>{{localize "TRESPASSER.Item.Features"}}</h4>
            <a class="item-create button" data-type="feature">+</a>
          </div>
          <ul class="items-list">
            {{#each features}}
            <li class="item" data-item-id="{{this.id}}">
              <span class="item-name feature-name rollable" title="{{localize 'TRESPASSER.Sheet.Combat.ClickView' name=this.name}}">{{this.name}}{{#if this.callingSource}} <span style="font-size:10px; color:var(--trp-text-dim); font-weight:normal;">({{this.callingSource}})</span>{{/if}}</span>
              <div class="item-controls">
                <a class="feature-info" title="{{localize 'TRESPASSER.Sheet.Equipments.Info'}}"><i class="fas fa-info-circle"></i></a>
                <a class="item-edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{else}}
            <li class="empty-list">{{localize "TRESPASSER.Sheet.Character.NoFeatures"}}</li>
            {{/each}}
          </ul>
        </div>
        <div class="features-panel">
          <div class="panel-header">
            <h4>{{localize "TRESPASSER.Item.Talents"}}</h4>
            <a class="item-create button" data-type="talent">+</a>
          </div>
          <ul class="items-list">
            {{#each talents}}
            <li class="item" data-item-id="{{this.id}}">
              <span class="item-name talent-rollable rollable" title="{{localize 'TRESPASSER.Sheet.Combat.ClickViewUse' name=this.name}}">
                {{#if this.displayCost}}{{this.displayCost}} | {{/if}}{{this.name}}{{#if this.callingSource}} <span style="font-size:10px; color:var(--trp-text-dim); font-weight:normal;">({{this.callingSource}})</span>{{/if}}
              </span>
              <div class="item-controls">
                <a class="talent-info" title="{{localize 'TRESPASSER.Sheet.Equipments.Info'}}"><i class="fas fa-info-circle"></i></a>
                <a class="item-edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
            {{else}}
            <li class="empty-list">{{localize "TRESPASSER.Sheet.Character.NoTalents"}}</li>
            {{/each}}
          </ul>
        </div>
      </div>

      <div class="features-panel incantations-panel" style="margin-top: 20px;">
        <div class="panel-header">
          <h4>{{localize "TRESPASSER.Item.Incantations"}}</h4>
          <a class="item-create button" data-type="incantation">+</a>
        </div>
        <ul class="items-list">
          {{#each incantations}}
          <li class="item" data-item-id="{{this.id}}">
            <span class="item-name incantation-rollable rollable" title="{{localize 'TRESPASSER.Sheet.Combat.ClickUse' name=this.name}}">
              {{this.name}}
            </span>
            <div class="item-controls">
              <a class="incantation-info" title="{{localize 'TRESPASSER.Sheet.Equipments.Info'}}"><i class="fas fa-info-circle"></i></a>
              <a class="item-edit"><i class="fas fa-edit"></i></a>
              <a class="item-delete"><i class="fas fa-trash"></i></a>
            </div>
          </li>
          {{else}}
          <li class="empty-list">{{localize "TRESPASSER.Sheet.Character.NoIncantations"}}</li>
          {{/each}}
        </ul>
      </div>
    </div>

    <!-- ─── TAB 5: COMBAT ─── -->
    <div class="tab tab-body" data-group="primary" data-tab="combat">

      <div class="combat-top">
        <!-- Derived Stats -->
        <div class="combat-stats-grid">
          {{#each (array "initiative" "accuracy" "guard" "resist" "prevail" "tenacity" "focus" "speed") as |stat|}}
          <div class="combat-stat">
            {{#if (or (eq stat "focus") (eq stat "speed"))}}
            <span class="combat-stat-label" data-stat="{{stat}}">
              {{localize (concat "TRESPASSER.Sheet.Combat." (capitalize stat))}}
            </span>
            {{else}}
            <span class="combat-stat-label combat-stat-roll rollable"
                  data-stat="{{stat}}"
                  title="Roll 1d20 + {{stat}}">
              {{localize (concat "TRESPASSER.Sheet.Combat." (capitalize stat))}}
            </span>
            {{/if}}
            <input type="number"
                   name="system.combat.{{stat}}"
                   value="{{lookup ../system.combat stat}}"
                   {{#unless (eq stat "focus")}}readonly{{/unless}} />
          </div>
          {{/each}}
        </div>

        <!-- Equipment Snapshot -->
        <div class="combat-equipment">
          <h4>{{localize "TRESPASSER.Sheet.Combat.Equipment"}}</h4>
          <table class="combat-equip-table">
            <thead>
              <tr><th></th><th>{{localize "TRESPASSER.Sheet.Equipments.Die"}}</th><th>{{localize "TRESPASSER.Sheet.Equipments.Effect"}}</th><th>{{localize "TRESPASSER.Sheet.Combat.BrokenUsedShort"}}</th></tr>
            </thead>
            <tbody>
              {{#each (array "head" "arms" "body" "legs" "outer" "shield") as |slot|}}
              {{#with (lookup ../equippedArmor slot) as |item|}}
              <tr data-item-id="{{item.id}}">
                <td class="slot-label equip-rollable" data-slot="{{slot}}">{{capitalize slot}}</td>
                <td>
                  {{#if item}}{{item.system.armorDie}}{{else}}—{{/if}}
                </td>
                <td>
                  {{#if item}}{{item.effectSummary}}{{else}}—{{/if}}
                </td>
                <td class="col-used">
                  {{#if item}}
                  <input type="checkbox" class="item-broken-toggle" {{checked item.system.broken}} />
                  {{/if}}
                </td>
              </tr>
              {{/with}}
              {{/each}}
              {{!-- Weapon row still uses snapshot for now as weapons aren't items yet --}}
              {{!-- Dynamic Weapon Row --}}
              <tr>
                <td class="slot-label" style="vertical-align: middle;">
                  <div style="display:flex; flex-direction:column; gap:2px; padding: 2px 0;">
                    <label style="margin: 0; font-size: 9px; line-height: 1;">{{localize "TRESPASSER.Sheet.Equipments.Weapon"}}</label>
                    {{#if weaponModes}}
                    <select name="system.combat.weaponMode" class="weapon-mode-select" style="margin: 0;">
                      {{selectOptions weaponModes selected=system.combat.weaponMode valueAttr="key" labelAttr="label"}}
                    </select>
                    {{/if}}
                  </div>
                </td>
                <td style="vertical-align: middle; padding-top: 8px;">{{activeWeapon.die}}</td>
                <td style="vertical-align: middle; padding-top: 8px;" title="{{activeWeapon.effect}}">{{activeWeapon.effect}}</td>
                <td class="col-used"></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      {{> "systems/trespasser/templates/actor/parts/combat-effects.hbs"}}

      <!-- Deeds Section -->
      <div class="deeds-section" style="margin-top: 15px;">
        <h3 class="section-title" style="margin-bottom: 0;">{{localize "TRESPASSER.Sheet.Combat.Deeds"}}</h3>
        
        {{> "systems/trespasser/templates/actor/parts/deed-list.hbs"}}
      </div>

    </div><!-- /combat -->
  </section>
</form>
