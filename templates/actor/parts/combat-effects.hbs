      <!-- Combat Effects (States & active triggered effects) -->
      <div class="states-section">
        <h3 class="section-title" style="display: flex; justify-content: space-between; align-items: center;">
          {{localize "TRESPASSER.Sheet.Combat.States"}} / {{localize "TRESPASSER.Sheet.Combat.CombatEffects"}}
          <a class="item-create button" data-type="state">+ {{localize "TRESPASSER.Sheet.Character.AddItem"}}</a>
        </h3>
        <div class="combat-effects-list">
          {{#each activeEffects.combat}}
          <div class="effect-row combat-effect" data-item-id="{{this.id}}">
            <div class="effect-name">
              {{this.name}}
              <a class="effect-info" title="{{localize 'TRESPASSER.Sheet.Equipments.Info'}}"><i class="fas fa-info-circle"></i></a>
              <a class="effect-edit" title="{{localize 'TRESPASSER.General.Edit'}}"><i class="fas fa-edit"></i></a>
              {{#if this.sourceName}} <span style="font-size: 11px; font-weight: normal; color: var(--trp-text-dim);">({{this.sourceName}})</span>{{/if}}
            </div>
            
            {{#if this.durationSummary}}
              <div class="effect-duration-control" style="font-size: 10px; color: var(--trp-text-dim); display:flex; align-items:center; gap:4px;">
                <i class="fas fa-clock" style="opacity:0.6;"></i>
                <span>{{this.durationSummary}}</span>
              </div>
            {{/if}}

            {{#unless this.isOnlyReminder}}
            <div class="effect-mod">{{this.target}}: {{this.modifier}}</div>
            {{/unless}}
            
            <div class="effect-intensity-control">
              <label>{{localize "TRESPASSER.Item.int"}}</label>
              <input type="number" class="effect-intensity-input" value="{{this.intensity}}" />
            </div>

            {{#unless this.fromInjury}}
            <button type="button" class="effect-prevail prevail-btn">
              <i class="fas fa-dice"></i> {{localize "TRESPASSER.Sheet.Combat.Prevail"}}
            </button>
            {{/unless}}
            <a class="effect-remove" title="{{localize 'TRESPASSER.Item.RemoveEffect'}}"><i class="fas fa-trash"></i></a>
          </div>
          {{else}}
          <div class="empty-list">{{localize "TRESPASSER.Sheet.Equipments.Empty"}}</div>
          {{/each}}
        </div>
      </div>
