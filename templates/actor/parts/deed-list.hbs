        <div class="deeds-tiered-container">
          {{#each (array "light" "heavy" "mighty" "special") as |tier|}}
          {{#if (lookup ../deedsGrouped tier)}}
          <div class="deed-tier-group">
            <div class="deed-tier-label">{{localize (concat "TRESPASSER.Item.DeedTierChoices." (capitalize tier))}}</div>
            <div class="deed-tier-grid">
              {{#each (lookup ../deedsGrouped tier)}}
              <div class="deed-slot" data-item-id="{{this.id}}">
                <div class="deed-slot-header">
                  <span class="deed-slot-title deed-rollable rollable" title="{{localize 'TRESPASSER.Sheet.Combat.UseDeed'}}">{{this.name}}{{#if this.sourceName}} <span style="font-size: 11px; font-weight: normal; color: var(--trp-text-dim);">({{this.sourceName}})</span>{{/if}}</span>
                  <div style="display: flex; gap: 6px; align-items: center;">
                    {{#if this.showCost}}
                      <span class="deed-slot-skill">{{this.displayCost}}</span>
                    {{/if}}
                  </div>
                </div>
                <div class="deed-slot-subheader">
                  {{capitalize this.system.type}} {{capitalize this.system.actionType}} {{localize "TRESPASSER.Sheet.Combat.Vs"}} {{this.system.accuracyTest}} | {{this.system.target}}
                </div>
                
                {{!-- Render specific effect descriptions if they exist --}}
                <div class="deed-slot-descriptions" style="font-size: 15px; color: var(--trp-text-dim); margin-top: 4px; border-top: 1px dotted rgba(200,200,200,0.1); padding-top: 2px;">
                  {{#each (array "start" "before" "base" "hit" "spark" "after" "end") as |phase|}}
                    {{#with (lookup ../system.effects phase) as |pData|}}
                      {{#if (or pData.description pData.appliedEffects.length)}}
                        <div style="margin-bottom: 2px;">
                          <em style="color: var(--trp-gold-dim); font-size: 15px; text-transform: uppercase;">{{localize (concat "TRESPASSER.Item." (capitalize phase))}}</em>: 
                          {{#if pData.description}}{{pData.description}}{{/if}}
                        </div>
                      {{/if}}
                    {{/with}}
                  {{/each}}
                </div>
                
                <div class="deed-slot-controls">
                  <a class="item-edit" title="{{localize 'TRESPASSER.Sheet.Equipments.Edit'}}"><i class="fas fa-edit"></i></a>
                  <a class="item-delete" title="{{localize 'TRESPASSER.Sheet.Equipments.Delete'}}"><i class="fas fa-trash"></i></a>
                </div>

              </div>
              {{/each}}
            </div>
          </div>
          {{/if}}
          {{/each}}
        </div>
