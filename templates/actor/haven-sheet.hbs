<section class="{{cssClass}} trespasser-sheet actor haven" autocomplete="off">
  <header class="sheet-header">
    <div class="header-portrait">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" />
    </div>

    <div class="header-info">
      <div class="header-row header-identity">
        <div class="name-group">
          <input type="text" name="name" value="{{actor.name}}" placeholder="{{localize 'TRESPASSER.Haven.NamePlaceholder'}}" {{disabled (not editable)}} />
        </div>
        
        {{!-- Top-right Leader Display --}}
        <div class="header-leader-mini drop-zone {{#if leader}}has-leader{{/if}}" data-action="dropLeader">
          <label>{{localize "TRESPASSER.Haven.Leader"}}</label>
          {{#if leader}}
            <div class="leader-badge" data-action="openLeaderSheet">
              <span class="name">{{leader.name}}</span>
              {{#if editable}}
                <a class="remove-leader" data-action="removeLeader" title="{{localize 'TRESPASSER.Remove'}}"><i class="fas fa-times"></i></a>
              {{/if}}
            </div>
          {{else}}
            <span class="placeholder">{{localize "TRESPASSER.Haven.DropLeaderHint"}}</span>
          {{/if}}
        </div>
      </div>

      <div class="header-row header-resources">
        <div class="resource-box">
          <label>{{localize "TRESPASSER.Haven.Treasury"}}</label>
          <input type="number" name="system.treasury" value="{{system.treasury}}" data-dtype="Number" {{disabled (not editable)}} />
        </div>
        <div class="resource-box balance-box {{#if isOverBudget}}over-budget{{/if}}">
          <label>{{localize "TRESPASSER.Haven.WeeklyBalance"}} <span class="breakdown-info" title="{{localize 'TRESPASSER.Haven.TreasuryBreakdown'}}"><i class="fas fa-info-circle"></i></span></label>
          <div class="balance-display">
            <input type="text" value="{{#if (gte weeklyBalance 0)}}+{{/if}}{{weeklyBalance}}" disabled />
          </div>
          <div class="balance-popover">
            <h5>
              <span>{{localize 'TRESPASSER.Haven.WeeklyIncome'}}</span>
              <span>+{{totalWeeklyIncome}}</span>
            </h5>
            <ul>
              {{#each breakdown.income}}<li><span>{{this.label}}</span> <span class="val">+{{this.value}}</span></li>{{/each}}
            </ul>
            <hr>
            <h5>
              <span>{{localize 'TRESPASSER.Haven.WeeklyExpenses'}}</span>
              <span>-{{totalWeeklyExpenses}}</span>
            </h5>
            <ul>
              {{#each breakdown.expenses}}<li><span>{{this.label}}</span> <span class="val">-{{this.value}}</span></li>{{/each}}
            </ul>
          </div>
        </div>
        <div class="resource-box {{#if system.isStagnant}}stagnant{{/if}} {{#if (eq system.populationState 'decline')}}decline{{/if}}" title="{{#if system.isStagnant}}{{localize 'TRESPASSER.Haven.StagnationDesc'}}{{/if}}">
          <label>{{localize "TRESPASSER.Haven.PopulationRank"}}</label>
          <div class="pop-rank-wrapper">
            <input type="number" name="system.populationRank" value="{{system.populationRank}}" data-dtype="Number" {{disabled (not editable)}} />
            {{#if editable}}
              <select name="system.populationState" class="pop-state-select">
                <option value="growth" {{#if (eq system.populationState 'growth')}}selected{{/if}}>{{localize "TRESPASSER.Haven.Growth"}}</option>
                <option value="decline" {{#if (eq system.populationState 'decline')}}selected{{/if}}>{{localize "TRESPASSER.Haven.Decline"}}</option>
              </select>
            {{else}}
              <span class="pop-state-tag {{system.populationState}}">{{localize (concat "TRESPASSER.Haven." (capitalize system.populationState))}}</span>
            {{/if}}
          </div>
          {{#if system.isStagnant}}<span class="stagnant-label">{{localize "TRESPASSER.Haven.Stagnant"}}</span>{{/if}}
        </div>
        <div class="resource-box">
          <label>{{localize "TRESPASSER.Haven.Level"}}</label>
          <input type="number" name="system.level" value="{{system.level}}" data-dtype="Number" {{disabled (not editable)}} />
        </div>
        <div class="resource-box">
          <label>{{localize "TRESPASSER.Haven.SkillBonus"}}</label>
          <input type="number" value="{{system.skillBonus}}" disabled />
        </div>
      </div>

      <div class="header-row header-attributes">
        {{#each (array "military" "efficiency" "resources" "expertise" "allegiance" "appeal") as |attr|}}
        <div class="attribute-box">
          <span class="attribute-label rollable" data-action="rollAttribute" data-attribute="{{attr}}">
            {{localize (concat "TRESPASSER.Haven.Attributes." (capitalize attr))}}
            <h3>{{lookup ../totalAttributes attr}}</h3>
          </span>
          <input type="number" name="system.attributes.{{attr}}" value="{{lookup ../system.attributes attr}}" {{disabled (not ../editable)}} />
        </div>
        {{/each}}
      </div>
    </div>
  </header>

  {{#if isGM}}
  <section class="haven-upkeep-section">
    <h3 class="section-title">{{localize "TRESPASSER.Haven.UpkeepHeader"}}</h3>
    <div class="upkeep-buttons">
      <button type="button" class="upkeep-btn" data-action="upkeepWeeksRest" title="{{localize 'TRESPASSER.Haven.WeeksRestFlavor'}}">
        <i class="fas fa-bed"></i> {{localize "TRESPASSER.Haven.UpkeepSteps.WeeksRest"}}
      </button>
      <button type="button" class="upkeep-btn" data-action="processWeek" title="{{localize 'TRESPASSER.Haven.ResolveProductionFlavor'}}">
        <i class="fas fa-users-cog"></i> {{localize "TRESPASSER.Haven.UpkeepSteps.ResolveProduction"}}
      </button>
      <button type="button" class="upkeep-btn" data-action="upkeepPopulationCheck" title="{{localize 'TRESPASSER.Haven.PopulationCheckFlavor'}}">
        <i class="fas fa-users"></i> {{localize "TRESPASSER.Haven.UpkeepSteps.PopulationCheck"}}
      </button>
      <button type="button" class="upkeep-btn" data-action="upkeepEventCheck" title="{{localize 'TRESPASSER.Haven.EventCheckFlavor'}}">
        <i class="fas fa-exclamation-triangle"></i> {{localize "TRESPASSER.Haven.UpkeepSteps.EventCheck"}}
      </button>
    </div>
  </section>
  {{/if}}


  {{!-- Tabs --}}
  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="skills">{{localize "TRESPASSER.Haven.SkillsLabel"}}</a>
    <a class="item" data-tab="buildings">{{localize "TRESPASSER.Haven.BuildingsLabel"}}</a>
    <a class="item" data-tab="hirelings">{{localize "TRESPASSER.Haven.ProductionChains"}}</a>
    <a class="item" data-tab="event">{{localize "TRESPASSER.Haven.Event"}}</a>
    <a class="item" data-tab="strongholds">{{localize "TRESPASSER.Haven.Strongholds"}}</a>
    <a class="item" data-tab="notes">{{localize "TRESPASSER.Haven.Notes"}}</a>
  </nav>

  <section class="sheet-content" data-scrollable="true">
    
    {{!-- Production Chains Tab --}}
    {{!-- Buildings Tab --}}
    <div class="tab" data-group="primary" data-tab="buildings">
      <div class="buildings-layout drop-zone" data-action="dropItem">
        
        {{!-- Under Construction --}}
        <div class="buildings-section">
          <h3 class="section-title">
            {{localize "TRESPASSER.Haven.UnderConstruction"}}
            <span class="limit-count">({{numConstruction}} / {{maxBuildSlots}})</span>
          </h3>
          <div class="buildings-grid">
            {{#each constructionBuildings as |b|}}
              <div class="building-card item" data-item-id="{{b.id}}">
                <div class="card-header">
                  <img src="{{b.img}}" data-action="editItem" title="{{b.name}}" />
                  <div class="header-info">
                    <span class="name" data-action="editItem">{{b.name}}</span>
                    <div class="bonus-list">
                      {{#each b.system.bonuses as |bonus|}}
                        <span class="bonus-tag">{{capitalize bonus.attribute}} +{{bonus.value}}</span>
                      {{/each}}
                    </div>
                  </div>
                  {{#if ../editable}}
                    <div class="card-controls">
                      <a class="edit-item" data-action="editItem" title="Edit Building"><i class="fas fa-edit"></i></a>
                      <a class="delete-item" data-action="deleteItem" title="{{localize 'TRESPASSER.General.Delete'}}"><i class="fas fa-trash"></i></a>
                    </div>
                  {{/if}}
                </div>
                <div class="card-body">
                  {{#if b.system.replacesId}}
                    <div class="replaces-hint">
                      <i class="fas fa-hammer"></i> Upgrading existing building
                    </div>
                  {{/if}}
                  <div class="clock-controls">
                    <label>{{localize "TRESPASSER.Haven.Build.BuildClock"}}</label>
                    <div class="controls-row">
                      <a data-action="adjustBuildClock" data-delta="-1"><i class="fas fa-minus"></i></a>
                      <span class="clock-value">{{b.system.progress}} / {{b.system.buildClock}}</span>
                      <a data-action="adjustBuildClock" data-delta="1"><i class="fas fa-plus"></i></a>
                    </div>
                  </div>
                </div>
              </div>
            {{else}}
              <div class="empty-placeholder mini">
                <p>{{localize "TRESPASSER.General.None"}}</p>
              </div>
            {{/each}}
          </div>
        </div>

        {{!-- Completed Buildings --}}
        <div class="buildings-section">
          <h3 class="section-title">
            {{localize "TRESPASSER.Haven.CompletedBuildings"}}
            <span class="limit-count">({{numCompleted}} / {{maxBuildingLimit}})</span>
          </h3>
          <div class="buildings-grid">
            {{#each completedBuildings as |b|}}
              <div class="building-card item completed" data-item-id="{{b.id}}">
                <div class="card-header">
                  <img src="{{b.img}}" data-action="editItem" title="{{b.name}}" />
                  <div class="header-info">
                    <span class="name" data-action="editItem">{{b.name}}</span>
                    <div class="bonus-list">
                      {{#each b.system.bonuses as |bonus|}}
                        <span class="bonus-tag">{{capitalize bonus.attribute}} +{{bonus.value}}</span>
                      {{/each}}
                    </div>
                  </div>
                  {{#if ../editable}}
                    <div class="card-controls">
                      {{#if b.system.upgradeTo}}
                        <a class="upgrade-item" data-action="upgradeBuilding" title="Upgrade"><i class="fas fa-arrow-up"></i></a>
                      {{/if}}
                      <a class="edit-item" data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
                      <a class="delete-item" data-action="deleteItem" title="{{localize 'TRESPASSER.General.Delete'}}"><i class="fas fa-trash"></i></a>
                    </div>
                  {{/if}}
                </div>
                <div class="card-body">
                  {{#if b.system.skills.length}}
                    <div class="skill-tags">
                      {{#each b.system.skills as |sk|}}
                        <div class="skill-tag">
                            <i class="fas fa-graduation-cap"></i> {{localize (concat "TRESPASSER.Haven.Skills." (capitalize sk))}}
                        </div>
                      {{/each}}
                    </div>
                  {{/if}}
                </div>
              </div>
            {{else}}
              <div class="empty-placeholder mini">
                <p>{{localize "TRESPASSER.General.None"}}</p>
              </div>
            {{/each}}
          </div>
        </div>

      </div>
    </div>

    {{!-- Hirelings Tab --}}
    <div class="tab" data-group="primary" data-tab="hirelings">
      <div class="hirelings-grid">
        {{#each hirelings as |h|}}
          <div class="hireling-card {{#if h.system.active}}active{{else}}inactive{{/if}}" data-item-id="{{h.id}}">
            <div class="card-info" data-action="openItemSheet">
              <div class="details">
                <span class="name">{{h.name}}</span>
                <span class="cost">{{h.system.cost}} / {{localize "TRESPASSER.Haven.Week"}}</span>
              </div>
            </div>
            <div class="card-controls">
              <input type="checkbox" class="hireling-active-toggle" data-action="toggleHirelingActive" data-item-id="{{h.id}}" {{checked h.system.active}} {{disabled (not ../editable)}} />
              {{#if ../editable}}
                <a class="delete-item" data-action="deleteItem" data-item-id="{{h.id}}"><i class="fas fa-trash"></i></a>
              {{/if}}
            </div>
          </div>
        {{else}}
          <p class="placeholder">{{localize "TRESPASSER.Haven.NoHirelingsHint"}}</p>
        {{/each}}
      </div>

      {{!-- Production Chains (Embedded in Hirelings) --}}
      <div class="production-chains-section">
        <h3 class="section-title">
          {{localize "TRESPASSER.Haven.ProductionChains"}}
          {{#if editable}}
            <a class="item-create button mini" data-type="productionChain" data-action="addChain" style="margin-left: 10px; font-size: 10px; padding: 2px 6px;">+ {{localize "TRESPASSER.Haven.AddProductionChainItem"}}</a>
          {{/if}}
        </h3>
        
        <div class="production-chains-list">
          {{#each system.productionChains as |chain chainIndex|}}
            <div class="production-chain {{#if chain.active}}active{{else}}inactive{{/if}}" data-chain-id="{{chain.id}}">
              <div class="chain-header flex-row">
                <input type="checkbox" class="chain-active-toggle" data-action="toggleChain" data-chain-index="{{chainIndex}}" {{checked chain.active}} {{disabled (not ../editable)}} />
                <input type="text" class="chain-name-input" data-action="updateChainName" data-chain-index="{{chainIndex}}" value="{{chain.name}}" {{disabled (not ../editable)}} />
                {{#if ../editable}}
                <div class="chain-controls">
                  <button type="button" class="remove-chain-btn" data-action="removeChain" data-chain-index="{{chainIndex}}"><i class="fas fa-trash"></i></button>
                </div>
                {{/if}}
              </div>
              <div class="chain-hirelings">
                {{#each chain.resolvedHirelings as |h hIndex|}}
                  <div class="hireling-entry {{#unless h.system.active}}inactive{{/unless}}" data-item-id="{{h.id}}">
                    <span class="name">{{h.name}}</span>
                    {{#if ../../editable}}
                    <div class="entry-controls">
                      <a class="remove-from-chain" data-action="removeHirelingFromChain" data-chain-index="{{../chainIndex}}" data-hireling-index="{{../hIndex}}"><i class="fas fa-times"></i></a>
                    </div>
                    {{/if}}
                  </div>
                {{/each}}
                
                {{#if (and ../editable ../availableHirelings.length)}}
                  <div class="add-hireling-to-chain-container flex-row">
                    <select class="available-hirelings-select">
                      <option value="">-- {{localize "TRESPASSER.Haven.AddHireling"}} --</option>
                      {{#each ../availableHirelings as |avail|}}
                        <option value="{{avail.id}}">{{avail.name}}</option>
                      {{/each}}
                    </select>
                    <button type="button" data-action="addHirelingToChain" data-chain-index="{{chainIndex}}"><i class="fas fa-plus"></i></button>
                  </div>
                {{/if}}
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    </div>



    {{!-- Attributes & Skills Tab --}}
    <div class="tab" data-group="primary" data-tab="skills">
      <div class="haven-skills-projects-layout">
        <div class="haven-skills-section">
          <h3 class="section-title">{{localize "TRESPASSER.Haven.SkillsLabel"}}</h3>
          <div class="skills-columns">
            {{#each skillColumns as |column|}}
            <div class="skill-column">
              {{#each column}}
              <div class="skill-row">
                <input type="checkbox" name="system.skills.{{this.key}}" {{checked this.trained}} {{disabled (not ../../editable)}} />
                <span class="skill-label rollable" data-action="rollSkill" data-skill="{{this.key}}" data-trained="{{this.trained}}">
                  {{this.label}}
                </span>
              </div>
              {{/each}}
            </div>
            {{/each}}
          </div>
        </div>

        <div class="haven-projects-section">
          <h3 class="section-title">
            {{localize "TRESPASSER.Haven.Projects"}}
            {{#if editable}}
              <a class="item-create button mini" data-action="addProject" title="{{localize 'TRESPASSER.Haven.AddProject'}}"><i class="fas fa-plus"></i></a>
            {{/if}}
          </h3>
          
          <div class="projects-list">
            {{#each projects as |p pIndex|}}
              <div class="project-item" data-project-id="{{p.id}}">
                <input type="text" name="system.projects.{{pIndex}}.name" value="{{p.name}}" class="project-name-input" {{disabled (not ../editable)}} />

                <div class="project-clock-mini">
                  {{> "systems/trespasser/templates/actor/parts/clock.hbs" 
                      id=p.id 
                      current=p.current 
                      max=p.clock 
                      segments=p.segments
                      action="projectClockClick"
                      showMax=false
                  }}
                </div>
                
                <div class="project-clock-config">
                    <label>{{localize "TRESPASSER.Haven.ClockMax"}}</label>
                    <input type="number" name="system.projects.{{pIndex}}.clock" value="{{p.clock}}" min="2" max="12" {{disabled (not ../editable)}} />
                </div>

                {{#if ../editable}}
                  <a class="delete-project" data-action="removeProject" title="{{localize 'TRESPASSER.General.Delete'}}"><i class="fas fa-trash"></i></a>
                {{/if}}
              </div>
            {{else}}
              <p class="placeholder">{{localize "TRESPASSER.Haven.NoProjectsHint"}}</p>
            {{/each}}
          </div>
        </div>

        <div class="haven-inventory-section">
          <h3 class="section-title">
            {{localize "TRESPASSER.Haven.Inventory"}}
          </h3>
          <div class="inventory-list drop-zone" data-action="dropItem">
            {{#each inventory as |entry|}}
              <div class="inventory-item" data-index="{{entry.index}}">
                <span class="name">{{entry.name}}</span>
                <div class="quantity-controls">
                  {{#if ../editable}}<a data-action="adjustInventoryQty" data-delta="-1"><i class="fas fa-minus"></i></a>{{/if}}
                  <span class="quantity">x{{entry.quantity}}</span>
                  {{#if ../editable}}<a data-action="adjustInventoryQty" data-delta="1"><i class="fas fa-plus"></i></a>{{/if}}
                </div>
                <div class="item-details">
                   <span class="type">{{entry.item.type}}</span>
                   {{#if entry.item.system.subType}}<span class="subtype">({{entry.item.system.subType}})</span>{{/if}}
                </div>
                <div class="controls">
                  <a class="withdraw-item" data-action="withdrawInventoryItem" title="{{localize 'TRESPASSER.Haven.Withdraw'}}"><i class="fas fa-box-open"></i></a>
                  {{#if ../editable}}
                    <a class="delete-item" data-action="deleteInventoryItem" title="{{localize 'TRESPASSER.DeleteItemTitle'}}"><i class="fas fa-trash"></i></a>
                  {{/if}}
                </div>
              </div>
            {{else}}
               <p class="placeholder">{{localize "TRESPASSER.Haven.DropItemHint"}}</p>
            {{/each}}
          </div>
        </div>
      </div>
    </div>

    <div class="tab" data-group="primary" data-tab="event">
      <div class="haven-event-layout">
        <div class="event-left-panel">
           <div class="event-title-group">
              <label>{{localize "TRESPASSER.Haven.EventTitle"}}</label>
              <input type="text" name="system.event.title" value="{{system.event.title}}" placeholder="{{localize 'TRESPASSER.Haven.EventPlaceholder'}}" />
           </div>

           <div class="event-description">
             <label>{{localize "TRESPASSER.General.Description"}}</label>
             <prose-mirror name="system.event.description" value="{{system.event.description}}" toggled="false" compact="false" {{#if (not editable)}}readonly{{/if}}>{{{enrichedEventDescription}}}</prose-mirror>
           </div>
        </div>

        <div class="event-right-panel">
           <div class="event-clock-display">
              <div class="event-clock-widget">
                {{> "systems/trespasser/templates/actor/parts/clock.hbs" 
                    current=eventClockCurrent 
                    max=eventClockTotal 
                    segments=eventClockSegments
                    action="eventClockClick"
                    showMax=true
                }}
              </div>
             <label class="clock-title">{{localize "TRESPASSER.Haven.Clock"}}</label>
           </div>

           <div class="clock-config-container shadow-box">
              <div class="field">
                <label>{{localize "TRESPASSER.Haven.ClockMax"}}</label>
                <input type="number" name="system.event.clock" value="{{system.event.clock}}" min="2" max="12" />
              </div>
           </div>
        </div>
      </div>

      {{!-- Arrivals (Embedded in Event) --}}
      <div class="haven-arrivals-section">
        <h3 class="section-title">{{localize "TRESPASSER.Haven.Arrivals"}}</h3>
        <prose-mirror name="system.arrivals" value="{{system.arrivals}}" toggled="false" compact="false" {{#if (not editable)}}readonly{{/if}}>{{{enrichedArrivals}}}</prose-mirror>
      </div>
    </div>

    {{!-- Strongholds Tab --}}
    <div class="tab" data-group="primary" data-tab="strongholds">
      <div class="stronghold-list drop-zone {{#if editable}}editable{{/if}}" data-action="dropStronghold">

        {{!-- Under Construction --}}
        <div class="buildings-section">
          <h3 class="section-title">
            {{localize "TRESPASSER.Haven.StrongholdUnderConstruction"}}
          </h3>
          <div class="buildings-grid">
            {{#each constructionStrongholds as |s|}}
              <div class="building-card item" data-item-id="{{s.id}}">
                <div class="card-header">
                  <img src="{{s.img}}" data-action="editItem" title="{{s.name}}" />
                  <div class="header-info">
                    <span class="name" data-action="editItem">{{s.name}}</span>
                    <div class="owner-name-mini">{{s.ownerName}}</div>
                  </div>
                  {{#if ../editable}}
                    <div class="card-controls">
                      <a class="edit-item" data-action="editItem" title="Edit Item"><i class="fas fa-edit"></i></a>
                      <a class="delete-item" data-action="deleteItem" title="{{localize 'TRESPASSER.General.Delete'}}"><i class="fas fa-trash"></i></a>
                    </div>
                  {{/if}}
                </div>
                <div class="card-body">
                  <div class="clock-controls">
                    <label>{{localize "TRESPASSER.Haven.Build.BuildClock"}}</label>
                    <div class="controls-row">
                      <a data-action="adjustBuildClock" data-delta="-1"><i class="fas fa-minus"></i></a>
                      <span class="clock-value">{{s.system.progress}} / {{s.system.buildClock}}</span>
                      <a data-action="adjustBuildClock" data-delta="1"><i class="fas fa-plus"></i></a>
                    </div>
                    <div class="progress-bar-container">
                       <div class="progress-bar-fill" style="width: {{math (math s.system.progress '/' s.system.buildClock) '*' 100}}%"></div>
                    </div>
                  </div>
                </div>
              </div>
            {{else}}
              <div class="empty-placeholder mini">
                <p>{{localize "TRESPASSER.General.None"}}</p>
              </div>
            {{/each}}
          </div>
        </div>
        
        {{!-- Completed Strongholds --}}
        <div class="buildings-section">
          <h3 class="section-title">
            {{localize "TRESPASSER.Haven.CompletedStrongholds"}}
          </h3>
          <div class="buildings-grid">
            {{#each completedStrongholds as |s|}}
              <div class="building-card item completed" data-item-id="{{s.id}}">
                <div class="card-header">
                  <img src="{{s.img}}" data-action="editItem" title="{{s.name}}" />
                  <div class="header-info">
                    <span class="name" data-action="editItem">{{s.name}}</span>
                    <div class="bonus-list">
                      {{#each s.system.bonuses as |bonus|}}
                        <span class="bonus-tag">{{capitalize bonus.attribute}} +{{bonus.value}}</span>
                      {{/each}}
                    </div>
                  </div>
                  {{#if ../editable}}
                    <div class="card-controls">
                      <a class="edit-item" data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
                      <a class="delete-item" data-action="deleteItem" title="{{localize 'TRESPASSER.General.Delete'}}"><i class="fas fa-trash"></i></a>
                    </div>
                  {{/if}}
                </div>
                <div class="card-body">
                   {{#if s.ownerName}}
                    <div class="owner-pill">
                       <i class="fas fa-crown"></i> {{s.ownerName}}
                    </div>
                   {{/if}}
                </div>
              </div>
            {{else}}
              <div class="empty-placeholder mini">
                <p>{{localize "TRESPASSER.General.None"}}</p>
              </div>
            {{/each}}
          </div>
        </div>

      </div>
    </div>

    {{!-- Notes Tab --}}
    <div class="tab" data-group="primary" data-tab="notes">
      <prose-mirror name="system.notes" value="{{system.notes}}" toggled="false" compact="false" {{#if (not editable)}}readonly{{/if}}>{{{enrichedNotes}}}</prose-mirror>
    </div>

  </section>
</section>
