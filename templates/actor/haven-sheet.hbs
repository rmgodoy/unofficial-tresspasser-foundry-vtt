<form class="{{cssClass}} trespasser-sheet actor haven" autocomplete="off">
  
  <header class="sheet-header">
    <div class="header-portrait" style="flex: 0 0 120px;">
      <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" style="width: 120px; height: 120px;" />
    </div>

    <div class="header-info">
      <!-- Title Row -->
      <div class="header-row header-identity">
        <div class="name-group">
          <input type="text" name="name" value="{{actor.name}}" placeholder="{{localize 'TRESPASSER.Sheet.Header.NamePlaceholder'}}" />
        </div>
        <div class="level-group">
          <label>Level</label>
          <input type="number" name="system.level" value="{{system.level}}" min="0" max="10" />
        </div>
        <div class="xp-group">
          <label>Pop. Rank</label>
          <input type="number" name="system.population_rank" value="{{system.population_rank}}" min="0" />
        </div>
      </div>

      <!-- Resources Row -->
      <div class="header-row header-resources">
        <div class="resource-box">
          <label>Wealth (CP)</label>
          <div class="resource-values">
            <input type="number" name="system.wealth" value="{{system.wealth}}" min="0" style="width: 60px;"/>
          </div>
        </div>
        <div class="resource-box">
          <label>Skill Bonus</label>
          <div class="resource-values">
            <span style="font-size: 16px; font-weight: bold; color: var(--trp-text-bright);">+{{system.skill_bonus}}</span>
          </div>
        </div>
        <div class="resource-box">
          <label>Build Slots</label>
          <div class="resource-values">
            <span style="font-size: 16px; font-weight: bold; color: var(--trp-text-bright);">{{buildings.inProgress.length}} / {{system.build_slots_max}}</span>
          </div>
        </div>
        <div class="resource-box">
          <label>Build Limit</label>
          <div class="resource-values">
            <span style="font-size: 16px; font-weight: bold; color: var(--trp-text-bright);">{{buildings.completed.length}} / {{system.building_limit}}</span>
          </div>
        </div>
        <div class="resource-box">
          <label>Expenses</label>
          <div class="resource-values">
            <span style="font-size: 16px; font-weight: bold; color: var(--trp-text-bright);">{{system.weekly_expenses}} CP</span>
          </div>
        </div>
      </div>

      <!-- Attributes Row -->
      <div class="header-row header-attributes" style="margin-top: 5px;">
        {{#each (array "military" "efficiency" "resources" "expertise" "allegiance" "appeal") as |attr|}}
        <div class="attribute-box">
          <span class="attribute-label">{{attr}}</span>
          <input type="number" name="system.attributes.{{attr}}" value="{{lookup ../system.attributes attr}}" min="0" max="5" />
        </div>
        {{/each}}
      </div>
    </div>
  </header>

  <!-- UPKEEP CONTROLS -->
  <div class="upkeep-controls" style="display: flex; gap: 10px; padding: 8px 12px; background: var(--trp-bg-dark); border-bottom: 2px solid var(--trp-border); align-items: center; justify-content: center; flex-wrap: wrap;">
    <strong style="color: var(--trp-gold-bright); font-family: var(--trp-font-header); text-transform: uppercase; font-size: 13px;">Upkeep Phase:</strong>
    <button type="button" class="upkeep-action" data-action="weeks-rest" style="flex: 0 0 auto; width: auto; padding: 2px 10px; font-size: 11px; font-family: var(--trp-font-header); text-transform: uppercase; letter-spacing: 0.05em;"><i class="fas fa-bed"></i> 1. Week's Rest</button>
    <button type="button" class="upkeep-action" data-action="pay-expenses" style="flex: 0 0 auto; width: auto; padding: 2px 10px; font-size: 11px; font-family: var(--trp-font-header); text-transform: uppercase; letter-spacing: 0.05em;"><i class="fas fa-coins"></i> 2. Pay Expenses</button>
    <button type="button" class="upkeep-action" data-action="population-check" style="flex: 0 0 auto; width: auto; padding: 2px 10px; font-size: 11px; font-family: var(--trp-font-header); text-transform: uppercase; letter-spacing: 0.05em;"><i class="fas fa-users"></i> 3. Pop. Check</button>
    <button type="button" class="upkeep-action" data-action="event-check" style="flex: 0 0 auto; width: auto; padding: 2px 10px; font-size: 11px; font-family: var(--trp-font-header); text-transform: uppercase; letter-spacing: 0.05em;"><i class="fas fa-exclamation-triangle"></i> 4. Event Check</button>
  </div>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="buildings">Buildings</a>
    <a class="item" data-tab="hirelings">Hirelings</a>
    <a class="item" data-tab="strongholds">Strongholds</a>
    <a class="item" data-tab="events">Events & Notes</a>
  </nav>

  <section class="sheet-body">
    <!-- BUILDINGS TAB -->
    <div class="tab tab-body default-tab" data-group="primary" data-tab="buildings">
        <!-- I will use character-layout to add Skills sidebar here just for buildings -->
        <div class="character-layout" style="grid-template-columns: 200px 1fr; gap: 20px;">
            <div class="char-col char-skills">
                <h4 style="border-bottom: 1px solid var(--trp-border-light); padding-bottom: 5px; margin-bottom: 10px; color: var(--trp-gold-bright); text-transform: uppercase; font-family: var(--trp-font-header); text-align: center; font-size: 12px; letter-spacing: 0.1em;">Skills</h4>
                {{#each (array "agriculture" "construction" "commerce" "cuisine" "entertainment" "espionage" "faith" "hospitality" "research" "seafaring" "statecraft" "warfare") as |skill|}}
                <div class="skill-row" style="display: flex; align-items: center; justify-content: space-between;">
                    <span class="skill-label" style="{{#if (lookup ../system.skills skill)}}color: var(--trp-gold-bright); font-weight: bold;{{/if}}">
                        {{capitalize skill}}
                    </span>
                    <input type="checkbox" name="system.skills.{{skill}}" {{checked (lookup ../system.skills skill)}} style="width: 14px; height: 14px; margin: 0;"/>
                </div>
                {{/each}}
            </div>
            
            <div class="char-col" style="border: none; padding-right: 0;">
                <h3 style="border-bottom: 2px solid var(--trp-gold); color: var(--trp-gold-bright); font-family: var(--trp-font-header); text-transform: uppercase; font-size: 16px; margin-top: 0;">In Progress ({{buildings.inProgress.length}} / {{system.build_slots_max}})</h3>
                
                <div class="equip-section">
                    <table class="equip-table">
                        <thead>
                            <tr>
                                <th class="col-icon"></th>
                                <th>Building Name</th>
                                <th>Progress</th>
                                <th class="col-icon"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each buildings.inProgress as |item|}}
                            <tr class="item" data-item-id="{{item.id}}">
                                <td class="col-icon"><img src="{{item.img}}" style="width: 24px; height: 24px; border-radius: var(--trp-radius-sm);"/></td>
                                <td>
                                    <strong>{{item.name}}</strong>
                                    {{#if item.system.upgrades_from}}<br/><span style="font-size: 10px; color: var(--trp-text-dim);">Upgrades {{item.system.upgrades_from}}</span>{{/if}}
                                </td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 5px;">
                                        <a class="clock-step" data-id="{{item.id}}" data-step="-1" style="color: var(--trp-text-dim);"><i class="fas fa-minus-circle"></i></a>
                                        <span style="font-family: monospace; font-weight: bold;">{{item.system.clock.value}} / {{item.system.clock.max}}</span>
                                        <a class="clock-step" data-id="{{item.id}}" data-step="1" style="color: var(--trp-text-dim);"><i class="fas fa-plus-circle"></i></a>
                                    </div>
                                </td>
                                <td class="col-icon item-controls" style="font-size: 12px; white-space: nowrap;">
                                    <a class="item-edit"><i class="fas fa-edit"></i></a>
                                    <a class="item-delete" style="margin-left: 5px;"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                            {{else}}
                            <tr><td colspan="4" style="text-align: center; color: var(--trp-text-dim); font-style: italic; padding: 10px;">No buildings currently in progress.</td></tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>

                <h3 style="border-bottom: 2px solid var(--trp-gold); color: var(--trp-gold-bright); font-family: var(--trp-font-header); text-transform: uppercase; margin-top: 20px; font-size: 16px;">Completed ({{buildings.completed.length}} / {{system.building_limit}})</h3>
                
                <div class="equip-section">
                    <table class="equip-table">
                        <thead>
                            <tr>
                                <th class="col-icon"></th>
                                <th>Building Name</th>
                                <th>Effects</th>
                                <th class="col-icon"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each buildings.completed as |item|}}
                            <tr class="item" data-item-id="{{item.id}}">
                                <td class="col-icon"><img src="{{item.img}}" style="width: 24px; height: 24px; border-radius: var(--trp-radius-sm);"/></td>
                                <td><strong>{{item.name}}</strong></td>
                                <td>
                                    {{#if item.system.attribute_granted}}<span style="border: 1px solid var(--trp-border); padding: 1px 4px; border-radius: 2px; font-size: 10px; margin-right: 5px;">+1 {{capitalize item.system.attribute_granted}}</span>{{/if}}
                                    {{#if item.system.skill_granted}}<span style="border: 1px solid var(--trp-border); padding: 1px 4px; border-radius: 2px; font-size: 10px;">{{capitalize item.system.skill_granted}}</span>{{/if}}
                                </td>
                                <td class="col-icon item-controls" style="font-size: 12px; white-space: nowrap;">
                                    <a class="item-edit"><i class="fas fa-edit"></i></a>
                                    <a class="item-delete" style="margin-left: 5px;"><i class="fas fa-trash"></i></a>
                                </td>
                            </tr>
                            {{else}}
                            <tr><td colspan="4" style="text-align: center; color: var(--trp-text-dim); font-style: italic; padding: 10px;">No buildings completed yet.</td></tr>
                            {{/each}}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- HIRELINGS TAB -->
    <div class="tab tab-body" data-group="primary" data-tab="hirelings">
        <h3 style="border-bottom: 2px solid var(--trp-gold); color: var(--trp-gold-bright); font-family: var(--trp-font-header); text-transform: uppercase; margin-top: 0; font-size: 16px;">Retained Hirelings</h3>
        <div class="equip-section">
            <table class="equip-table">
                <thead>
                    <tr>
                        <th class="col-icon"></th>
                        <th>Name</th>
                        <th>Required Build</th>
                        <th style="text-align: center;">Qty</th>
                        <th style="text-align: right;">Cost (ea)</th>
                        <th style="text-align: right;">Total Cost</th>
                        <th class="col-icon"></th>
                    </tr>
                </thead>
                <tbody>
                    {{#each hirelings as |item|}}
                    <tr class="item" data-item-id="{{item.id}}">
                        <td class="col-icon"><img src="{{item.img}}" style="width: 24px; height: 24px; border-radius: var(--trp-radius-sm);"/></td>
                        <td><strong>{{item.name}}</strong></td>
                        <td>{{item.system.required_building}}</td>
                        <td style="text-align: center;">{{item.system.quantity}}</td>
                        <td style="text-align: right;">{{item.system.cost}}</td>
                        <td style="text-align: right;"><strong>{{math item.system.quantity '*' item.system.cost}} CP</strong></td>
                        <td class="col-icon item-controls" style="font-size: 12px; white-space: nowrap;">
                            <a class="item-edit"><i class="fas fa-edit"></i></a>
                            <a class="item-delete" style="margin-left: 5px;"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                    {{else}}
                    <tr><td colspan="7" style="text-align: center; color: var(--trp-text-dim); font-style: italic; padding: 10px;">No hirelings retained.</td></tr>
                    {{/each}}
                </tbody>
            </table>
        </div>
    </div>

    <!-- STRONGHOLDS TAB -->
    <div class="tab tab-body" data-group="primary" data-tab="strongholds">
        <h3 style="border-bottom: 2px solid var(--trp-gold); color: var(--trp-gold-bright); font-family: var(--trp-font-header); text-transform: uppercase; margin-top: 0; font-size: 16px;">Party Strongholds</h3>
        <div class="inventory-grid" style="grid-template-columns: repeat(2, 1fr); gap: 15px;">
            {{#each strongholds as |item|}}
            <div class="item inventory-card" data-item-id="{{item.id}}" style="align-items: stretch; text-align: left; padding: 12px;">
                <div style="display: flex; gap: 10px; align-items: flex-start; border-bottom: 1px solid var(--trp-border); padding-bottom: 8px; margin-bottom: 8px;">
                    <img src="{{item.img}}" style="width: 48px; height: 48px; border-radius: var(--trp-radius); border: 1px solid var(--trp-border);"/>
                    <div style="flex: 1;">
                        <h4 style="margin: 0; color: var(--trp-gold-bright); font-family: var(--trp-font-header); text-transform: uppercase;">{{item.name}}</h4>
                        <span style="font-size: 11px; color: var(--trp-text-dim);">Owner: <strong style="color: var(--trp-text);">{{item.system.owner}}</strong></span>
                    </div>
                    <div class="item-controls" style="position: static; display: flex;">
                        <a class="item-edit"><i class="fas fa-edit"></i></a>
                        <a class="item-delete" style="margin-left: 5px;"><i class="fas fa-trash"></i></a>
                    </div>
                </div>

                <div style="font-size: 12px; color: var(--trp-text); margin-bottom: 10px; max-height: 80px; overflow-y: auto;">
                    {{{item.system.description}}}
                </div>

                <div style="background: rgba(0,0,0,0.3); border: 1px solid var(--trp-border); border-radius: var(--trp-radius-sm); padding: 5px; text-align: center; margin-top: auto;">
                    {{#if item.system.completed}}
                      <span style="color: var(--trp-gold-bright); font-weight: bold; font-family: var(--trp-font-header); text-transform: uppercase; font-size: 12px; letter-spacing: 0.1em;">Completed</span>
                    {{else}}
                      <div style="display: flex; align-items: center; justify-content: center; gap: 10px;">
                        <a class="clock-step" data-id="{{item.id}}" data-step="-1" style="color: var(--trp-text-dim); cursor: pointer;"><i class="fas fa-minus-circle"></i></a>
                        <span style="font-family: monospace; font-size: 14px; font-weight: bold;">{{item.system.clock.value}} / {{item.system.clock.max}}</span>
                        <a class="clock-step" data-id="{{item.id}}" data-step="1" style="color: var(--trp-text-dim); cursor: pointer;"><i class="fas fa-plus-circle"></i></a>
                      </div>
                    {{/if}}
                </div>
            </div>
            {{else}}
            <div style="grid-column: 1 / -1; text-align: center; color: var(--trp-text-dim); font-style: italic; padding: 20px;">No strongholds established yet.</div>
            {{/each}}
        </div>
    </div>

    <!-- EVENTS & NOTES TAB -->
    <div class="tab tab-body" data-group="primary" data-tab="events">
        
        <div style="background: var(--trp-bg-dark); border: 1px solid var(--trp-border); border-radius: var(--trp-radius); padding: 12px; margin-bottom: 15px;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                <h4 style="margin: 0; color: var(--trp-gold-bright); font-family: var(--trp-font-header); text-transform: uppercase; letter-spacing: 0.1em;">Population Decline</h4>
                <div style="display: flex; align-items: center; gap: 8px;">
                    <label style="font-size: 11px; text-transform: uppercase; color: var(--trp-text-dim);">Active</label>
                    <input type="checkbox" name="system.population_decline.active" {{checked system.population_decline.active}} style="margin: 0;"/>
                </div>
            </div>
            <input type="text" name="system.population_decline.notes" value="{{system.population_decline.notes}}" placeholder="Notes regarding decline..." style="width: 100%; height: 30px; padding: 0 8px; background: var(--trp-bg-input); border: 1px solid var(--trp-border); color: var(--trp-text);" />
        </div>

        <h4 style="border-bottom: 1px solid var(--trp-border-light); padding-bottom: 5px; margin-bottom: 10px; color: var(--trp-gold-bright); text-transform: uppercase; font-family: var(--trp-font-header); font-size: 13px; letter-spacing: 0.1em;">Active Events</h4>
        <div style="border: 1px solid var(--trp-border); background: var(--trp-bg-dark); min-height: 150px; padding: 8px;">
        {{editor system.active_events target="system.active_events" engine="prosemirror" button=true owner=owner editable=editable}}
        </div>

        <h4 style="border-bottom: 1px solid var(--trp-border-light); padding-bottom: 5px; margin-top: 20px; margin-bottom: 10px; color: var(--trp-gold-bright); text-transform: uppercase; font-family: var(--trp-font-header); font-size: 13px; letter-spacing: 0.1em;">Haven Notes</h4>
        <div style="border: 1px solid var(--trp-border); background: var(--trp-bg-dark); min-height: 250px; padding: 8px;">
        {{editor system.notes target="system.notes" engine="prosemirror" button=true owner=owner editable=editable}}
        </div>

    </div>

  </section>
</form>
