<div class="trespasser chat-card peril-card">
    <header class="card-header flexrow" style="background: rgba(0,0,0,0.2); padding: 4px 8px; border-bottom: 1px solid var(--trp-gold-dim);">
        <h3 class="item-name" style="color: var(--trp-gold-bright); margin: 0; font-family: var(--trp-font-title); text-transform: uppercase; letter-spacing: 1px; font-size: var(--fs-14);">
            {{localize "TRESPASSER.Terms.Combat.Peril"}}
        </h3>
    </header>

    <div class="card-content" style="padding: 10px;">
        <div class="peril-total" style="font-size: var(--fs-28); font-weight: bold; text-align: center; color: var(--trp-gold-bright); text-shadow: 0 0 10px rgba(255, 215, 0, 0.3); margin: 5px 0;">
            {{total}} ({{label}})
        </div>
    </div>
</div>
